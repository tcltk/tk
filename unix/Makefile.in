#========================================================================
# Compile flags
#========================================================================

CFLAGS = @CFLAGS@ @XFT_CFLAGS@ @BIDI_CFLAGS@ \
	$(EXTRA_CFLAGS) \
	$(XINCLUDES) \
	-DTK_LIBRARY=\"$(TK_LIBRARY)\" \
	-DTK_VERSION=\"$(VERSION)\" \
	-DTK_PATCH_LEVEL=\"$(TK_PATCH_LEVEL)\"

CPPFLAGS = @CPPFLAGS@

# Additional definitions from configure
DEFS = @DEFS@

#========================================================================
# Link flags and libraries
#========================================================================

LIBS = @LIBS@ @XFT_LIBS@ @XLIBSW@

#========================================================================
# Installation
#========================================================================

SHELL = @SHELL@
INSTALL = @INSTALL@
INSTALL_DATA = @INSTALL_DATA@
INSTALL_PROGRAM = @INSTALL_PROGRAM@
INSTALL_SCRIPT = @INSTALL_SCRIPT@

#========================================================================
# Rules
#========================================================================

.c.o:
	$(CC) -c $(CFLAGS) $(CPPFLAGS) $(DEFS) $<

# Build the library
libtk$(VERSION).a: $(TK_OBJS)
	$(AR) cr $@ $(TK_OBJS)
	$(RANLIB) $@

# You may need to adjust the shared library rule if your configure uses a different name
$(TK_LIB_FILE): $(TK_OBJS)
	$(SHLIB_LD) -o $@ $(TK_OBJS) $(LIBS) $(SHLIB_LD_LIBS)

# Install targets (simplified - keep your existing ones and just ensure they use the variables)
install: install-binaries install-libraries

install-binaries: $(TK_LIB_FILE)
	# ... (keep your existing install rules)

# Clean
clean:
	rm -f *.o libtk*.a $(TK_LIB_FILE) core

distclean: clean
	rm -f Makefile config.status config.cache config.log tkConfig.sh

# Dependencies (add more if needed)
$(TK_OBJS): tkInt.h tkPort.h default.h

.PHONY: all clean distclean install
