	text .t -undo 1
	.t debug 1
	.t insert end "aaabbbccc"
	.t tag add B 1.3 1.6
	.t tag configure B -elide 1
	.t delete {*}$del
	destroy .t
    }
    text .t -undo 1
    .t debug 1
    .t insert end "aaabbbcccdddeee"
    .t tag add E1 1.3 1.6
    .t tag add E2 1.9 1.12
    .t tag configure E1 -elide 1
    .t tag configure E2 -elide 1
    .t delete 1.4 1.11
    destroy .t
} -cleanup {
    destroy .t
} -result {}

