    .t tag add E1 2.0 2.1
    .t tag add E2 2.1 2.2
    .t tag configure E0 -elide 1
    .t tag configure E1 -elide 1
    .t tag configure E2 -elide 1
    .t mark set fuzzmark 2.0
    .t delete 1.1 1.2
    .t delete 2.0 2.1
    .t delete 1.2 2.0
    .t debug 0
