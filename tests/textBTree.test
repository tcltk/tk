    .t edit undo
    .t delete 1.4 end
    lappend res [.t get 1.0 end-1c] [.t tag ranges E0]
} -cleanup {
    destroy .t
} -result {abcd {1.2 1.4} abcdefgh {1.2 2.0} abcd {1.2 1.4} abcd {1.2 1.4}}

