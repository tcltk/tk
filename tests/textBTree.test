test btree-14.27 {no join of delete undo tokens holding switches} -setup {
    destroy .t
} -body {
    text .t -undo 1
    .t debug 1
    .t insert end "aXXYYb"
    .t tag add B 1.1 1.5
    .t tag configure B -elide 1
    .t edit reset
    .t delete 1.1 1.3
    .t delete 1.1 1.3
    set res [list [.t get 1.0 end-1c]]
    while {[.t edit canundo]} { .t edit undo }
    lappend res [.t get 1.0 end-1c] [.t tag ranges B]
    while {[.t edit canredo]} { .t edit redo }
    lappend res [.t get 1.0 end-1c]
    while {[.t edit canundo]} { .t edit undo }
    lappend res [.t tag ranges B]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {ab aXXYYb {1.1 1.5} ab {1.1 1.5}}

