test btree-14.95 {elide walk: dangling switch beyond the range resolved by elide state} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The re-pairing of a kept link takes the kept branch away from its
    # mutual old fork which lies beyond the processed range; the leftover
    # dangling link is resolved at walk exit from the actual elide state at
    # its position (remove when the preceding content is not elided anymore,
    # recompute the surrounding tag-elided range otherwise). Recorded fuzz
    # sequence (fuzz_tagops seed 847, multiline).
    .t debug on
    .t insert end {mglwzjrvyvhhrmntppswcsixwjx
phflavrk}
    .t tag configure E0 -elide 1
    .t tag configure E1 -elide 1 -undo 0
    .t tag configure T0 -underline 0
    .t tag configure T1 -undo 0 -underline 0
    .t edit reset
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.6 > 1.2
    .t compare 1.2 == 1.6
    .t tag remove T1 1.2 1.6
    .t edit separator
    .t index end-1c
    .t count -chars 2.0 {2.0 lineend}
    .t index end-1c
    .t count -chars 2.0 {2.0 lineend}
    .t compare 2.3 > 2.5
    .t compare 2.3 == 2.5
    .t tag remove E0 2.3 2.5
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.23 > 1.0
    .t compare 1.0 == 1.23
    .t tag clear 1.0 1.23
    .t edit separator
