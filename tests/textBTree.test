} -result {4 aiz}

test btree-14.53 {delete up to the branch after an untagged insert at a junction} -setup {
    destroy .t
    text .t
} -body {
    # Used to panic (misplaced branch), fuzz seed 251 family.
    .t debug 1
    .t insert end "abcdefgh"
