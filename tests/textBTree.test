test btree-14.55 {redo of an insert adjacent to an elided range start, switches annihilated meanwhile} -setup {
    destroy .t
    text .t -undo 1
} -body {
    .t debug 1
    .t insert end "bhb\nill"
    .t tag add E0 1.0 1.3
    .t tag configure E0 -elide 1
    .t insert 1.0 "ll"
    set res [list]
    .t edit undo   ;# undoes the whole atom: insert+tagadd+insert
    lappend res [.t get 1.0 end-1c]
    .t edit redo   ;# must not crash, must restore everything
    lappend res [.t get 1.0 end-1c] [.t tag ranges E0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result [list {} "llbhb\nill" {1.2 1.5}]

test btree-14.56 {undo of a delete bordering an elided range whose switches died by un-eliding} -setup {
    destroy .t
    text .t -undo 1
} -body {
    .t debug 1
    .t insert end "bhb\nill"
    .t tag add E0 1.0 1.3
    .t tag configure E0 -elide 1
    .t insert 1.0 "ll"
    .t edit separator
    .t delete 1.0 1.2
    .t tag configure E0 -elide 0
    set res [list]
    .t edit undo   ;# the enrolled branch is stale: must be dropped, not restored
    lappend res [.t get 1.0 end-1c] [.t tag ranges E0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result [list "llbhb\nill" {1.2 1.5}]

test btree-14.57 {link variant: redo of an insert adjacent to an elided range end} -setup {
    destroy .t
    text .t -undo 1
} -body {
    .t debug 1
    .t insert end "bhb\nill"
    .t tag add E0 1.0 1.3
    .t tag configure E0 -elide 1
    .t insert 1.3 "xx"
    set res [list]
    .t edit undo
    lappend res [.t get 1.0 end-1c]
    .t edit redo
    lappend res [.t get 1.0 end-1c] [.t tag ranges E0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result [list {} "bhbxx\nill" {1.0 1.3}]

test btree-14.58 {undo of a delete merging two elided ranges, unelided in the meantime} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # The switches dying inside the deletion stash their counterparts in
    # the token; the counterparts die afterwards by the un-eliding. The
    # stale stashes must be detected and dropped at the undo.
    .t debug 1
    .t insert end "aaabbbccc"
    .t tag add E0 1.0 1.3
    .t tag add E0 1.6 1.9
    .t tag configure E0 -elide 1
    .t edit separator
    .t delete 1.1 1.7
    .t tag configure E0 -elide 0
    .t edit undo
    set res [list [.t get 1.0 end-1c] [.t tag ranges E0] [.t get -displaychars 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {aaabbbccc {1.0 1.3 1.6 1.9} aaabbbccc}

test btree-14.64 {untagged insert at elide junction, another elided range follows} -setup {
    destroy .t
    text .t
} -body {
    # The recompute of the enclosing range must not extend over the
    # opening branch of the following elided range, else the inserted
    # branch of the trailing part steals the link of that range
    # ("related branch is not pointing to this link", fuzz seed 615).
    .t debug 1
    .t insert end "abcdefghijkl"
    foreach {tag a b} {E0 1.1 1.3 E1 1.3 1.5 E2 1.7 1.9} {
	.t tag add $tag $a $b
	.t tag configure $tag -elide 1
    }
    .t insert 1.3 "k"
    set res [list [.t get -displaychars 1.0 end-1c] [.t count -displaychars 1.0 end]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {akfgjkl 8}

test btree-14.65 {undo restoring whole untagged lines inside an elided range, -undo 0} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # The restored lines carry no tags at all; the recompute walk used to
    # skip them as unaffected, never splitting the range (wrong logicalLine).
    .t debug 1
    .t insert end "aaa\nbbb\nccc\nddd"
    .t tag configure E -elide 1 -undo 0
    .t tag add E 1.1 4.2
    .t edit separator
    .t delete 2.0 4.0
    .t edit undo
    set res [list [.t tag ranges E] [.t get -displaychars 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result [list {1.1 2.0 4.0 4.2} "abbb\nccc\nd"]

test btree-14.66 {untagged whole-line insert at the junction of two elide tags} -setup {
    destroy .t
    text .t
} -body {
    .t debug 1
    for {set i 1} {$i <= 10} {incr i} { .t insert end "line$i\n" }
    .t tag configure E0 -elide 1
    .t tag configure E1 -elide 1
    .t tag add E0 4.0 6.0
    .t tag add E1 6.0 8.0
    .t insert 6.0 "X\n"
    set res [list [.t tag ranges E0] [.t tag ranges E1] [.t get -displaychars 4.0 8.0]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result [list {4.0 6.0} {7.0 9.0} "X\n"]

test btree-14.67 {undo of a delete over a zone whose tag was unelided and re-elided} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # Two zones on the line: the recompute over the restored range must
    # not leave the second pair with an orphaned link.
    .t debug 1
    .t tag configure E -elide 1
    .t insert end "0123456789ABCDEFGHIJ0123456789"
    .t tag add E 1.3 1.7
    .t tag add E 1.12 1.16
    .t edit separator
    .t tag configure E -elide 0
    .t delete 1.0 1.6
    .t tag configure E -elide 1
    .t edit undo
    set res [list [.t tag ranges E] [.t get -displaychars 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{1.3 1.7 1.12 1.16} 012789ABGHIJ0123456789}

test btree-14.68 {redo after a reconciled undo, split of the middle of a range} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # The redo deletes exactly the gap between the two split zones; the
    # adjacent equal tagged chars must be merged again (the split points
    # are the dead switches).
    .t debug 1
    .t insert end "aaabbbbbccc"
    .t tag configure B -elide 1 -undo 0
    .t tag add B 1.3 1.8
    .t delete 1.4 1.7
    .t edit undo
    .t edit redo
    set res [list [.t get 1.0 end-1c] [.t tag ranges B]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {aaabbccc {1.3 1.5}}

test btree-14.69 {redo after a reconciled undo, deletion spanning two zones} -setup {
    destroy .t
    text .t -undo 1
} -body {
    .t debug 1
    .t insert end "aabbccddee"
    .t tag configure B -elide 1 -undo 0
    .t tag add B 1.2 1.4
    .t tag add B 1.6 1.8
    .t delete 1.3 1.7
    .t edit undo
    .t edit redo
    set res [list [.t get 1.0 end-1c] [.t tag ranges B]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {aabdee {1.2 1.4}}

test btree-14.70 {single char delete with a fragmented line before a tiny elided zone} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # The right boundary mark is unlinked after the rebuild: its shrunk
    # section had lost its permission to be short.
    .t debug 1
    .t tag configure el -elide 1
    .t tag configure t0 -underline 0
    .t tag configure t1 -underline 0
    set args {}
    for {set i 0} {$i < 39} {incr i} { lappend args "a" [list t[expr {$i % 2}]] }
    .t insert 1.0 {*}$args
    .t tag add el 1.38 1.39
    .t delete 1.0 1.1
    set res [string length [.t get 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {38}

test btree-14.71 {delete through a branch carrying piled up marks} -setup {
    destroy .t
    text .t -undo 1
} -body {
    .t debug 1
    .t insert end "[string repeat a 80]\n[string repeat b 40]"
    .t tag configure E2 -elide 1
    .t tag add E2 1.30 2.5
    for {set i 1} {$i <= 37} {incr i} { .t mark set m$i 1.30 }
    .t delete 1.25 1.35
    set res [string length [.t get 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {111}

test btree-14.72 {undo and redo of tag clear over an elide tag} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # The whole atom (insert, tag add, tag clear) is undone and redone;
    # the recompute of UndoClearTagsPerform needs protected range ends.
    .t debug 1
    .t insert end "aaabbbccc"
    .t tag configure B -elide 1
    .t tag add B 1.3 1.6
    .t edit separator
    .t tag clear 1.2 1.7
    set res {}
    .t edit undo
    lappend res [.t get 1.0 end-1c]
    .t edit redo
    lappend res [.t get 1.0 end-1c] [.t tag ranges B] [.t get -displaychars 1.0 end-1c]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{} aaabbbccc {} aaabbbccc}

test btree-14.73 {tag add of an elide tag: undo record must be set up before the elide update} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # UpdateElideInfo merges the char segments neighboring a removed switch
    # (zones merging as the elision extends); the segments recorded for the
    # undo range were freed before being converted to indices.
    .t debug 1
    .t tag configure E -elide 1
    .t insert end "abcdefghij0123456789ABCDEFGHIJ"
    .t tag add E 1.20 1.23
    .t insert 1.3 pqr
    .t tag add E 1.0 1.22
    .t insert 1.16 pqr
    .t delete 1.9 1.18
    .t tag add E 1.14 1.27
    set res [list [.t get 1.0 end-1c] [.t tag ranges E]]
    .t edit undo
    lappend res [.t get 1.0 end-1c]
    .t edit redo
    lappend res [.t get 1.0 end-1c] [.t tag ranges E]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {abcpqrdefr3456789ABCDEFGHIJ {1.0 1.27} {} abcpqrdefr3456789ABCDEFGHIJ {1.0 1.27}}

test btree-14.74 {tag clear of an untagged range, tagged content beyond the range} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # TkBTreeFindNextTagged returned a tagged segment beyond the search
    # range (the boundary lies within the first line, the node walk never
    # encounters it), so FindSplitPoints proceeded on the empty range and
    # produced twice the same split segment.
    .t debug 1
    .t insert end "abcdef\nghijkl"
    .t tag configure E -elide 1
    .t tag add E 2.1 2.3
    .t tag clear 1.0 1.3
    set res [list [.t get 1.0 end-1c] [.t tag ranges E]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result [list "abcdef\nghijkl" {2.1 2.3}]

test btree-14.75 {tag clear of content carrying only tags excluded from undo} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # Changes are made but nothing is recorded for undo: the undo range
    # setup dereferenced the null record.
    .t debug 1
    .t insert end "aaabbbccc"
    .t tag configure B -elide 1 -undo 0
    .t tag add B 1.3 1.6
    .t edit separator
    .t tag clear 1.2 1.7
    set res [list [.t tag ranges B] [.t get -displaychars 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{} aaabbbccc}

test btree-14.76 {tag clear of a subrange of an elided range} -setup {
    destroy .t
    text .t -undo 1
} -body {
    # The pre-clear strip of the range orphaned the switches of the
    # enclosing elided range (branch removed, link kept); the elide
    # topology is recomputed from the new tags after the clearing now.
    .t debug 1
    .t insert end "abcdefghij"
    .t tag configure E -elide 1
    .t tag add E 1.2 1.8
    .t edit separator
    .t tag clear 1.2 1.5
    set res [list [.t tag ranges E] [.t get -displaychars 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{1.5 1.8} abcdeij}

test btree-14.77 {removing the tail of an elided range starting on the first line} -setup {
    destroy .t
    text .t
} -body {
    # The branch search bailed out without ever examining the first line
    # of the node (off-by-one); the link insertion then found the start
    # marker instead of the enclosing branch.
    .t debug 1
    .t insert end "abcdefghij\nklmnop\nqrstuv"
    .t tag configure E0 -elide 1
    .t tag add E0 1.5 3.4
    .t tag remove E0 3.1 3.4
    set res [list [.t tag ranges E0]]
    .t tag add E0 1.5 3.4
    .t tag remove E0 3.1 3.3
    lappend res [.t tag ranges E0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{1.5 3.1} {1.5 3.1 3.3 3.4}}

test btree-14.78 {undo tag clear: first recorded segment on a later line} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The first skip of the change list was anchored on the start line of
    # the cleared range instead of the line of the first recorded segment
    # (the start index of the token): the undo walk overshot the document.
    .t debug 1
    .t insert end "aaaaaaaaaaaaaaaaaaaa\nbbbbbbbbbbbbb\ncccccccccccccccccccc"
    .t tag configure X -underline 1
    .t tag configure Y -underline 1
    .t edit reset
    .t tag add X 2.0 2.5
    .t edit separator
    .t tag add Y 3.4 3.9
    .t edit separator
    .t insert 1.0 q
    .t edit separator
    .t tag clear 2.8 3.19
    .t edit separator
    .t edit undo
    set res [list [.t tag ranges X] [.t tag ranges Y]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{2.0 2.5} {3.4 3.9}}

test btree-14.79 {tag clear across lines: the line cache must take references} -setup {
    destroy .t
    text .t -undo 0
} -body {
    # The cached tagon/tagoff result of the previous line was stored with
    # transfer semantics, stealing two references per cached line (double
    # free of the empty tag set at destroy).
    .t insert end "abcdefgh\nijklmnop"
    .t tag configure X -underline 1
    .t tag add X 1.1 2.1
    .t tag clear 1.0 2.3
    destroy .t
    set res ok
} -cleanup {
    destroy .t
} -result {ok}

test btree-14.81 {undo tag clear: interior segment boundaries must be merged} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # Boundaries introduced inside a restored chunk (tagging done between
    # the clearing and the undo, overwritten by the restore) left equal
    # tagged adjacent char segments behind.
    .t debug 1
    .t insert end "vmjiknbyvnvpwxnxgrzq"
    .t tag configure T0 -underline 0
    .t tag configure T1 -undo 0 -underline 0
    .t tag configure T2 -overstrike 0
    .t edit reset
    .t tag add T0 1.5 1.20
    .t edit separator
    .t tag add T2 1.11 1.19
    .t edit separator
    .t tag clear 1.0 1.12
    .t edit separator
    .t tag add T1 1.7 1.10
    .t edit separator
    while {[.t edit canundo]} { .t edit undo }
    set res [list [.t tag ranges T0] [.t tag ranges T1] [.t tag ranges T2]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{} {} {}}

test btree-14.82 {undo restoring a switch pair nested inside a newer elided range} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The verbatim restore produces a transiently nested switch chain; the
    # walk has to reconnect the kept branch with the kept link, and the
    # section checker must accept the unmergeable short section between
    # two links.
    .t debug 1
    .t insert end "[string repeat a 40]\n[string repeat b 27]"
    foreach {t opts} {E0 {-elide 1} E1 {-elide 1 -undo 0} T0 {-underline 0}} {
	.t tag configure $t {*}$opts
    }
    .t tag add T0 2.10 2.11
    .t tag add T0 2.11 2.12
    .t edit reset
    .t tag add E0 2.5 2.10
    .t edit separator
    .t delete 2.2 2.11
    .t edit separator
    .t tag add E1 1.35 2.3
    .t edit undo
    set res [list [.t tag ranges E0] [.t tag ranges E1] [string length [.t get 1.0 end-1c]]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{2.5 2.10} {1.35 2.2 2.11 2.12} 68}

test btree-14.83 {nested restore with a wide section between the two links} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # Same nesting with enough fragmented segments to pass the section
    # check: exercises the dangling reconnection of the kept switches.
    .t debug 1
    .t insert end "[string repeat a 40]\n[string repeat b 44]"
    foreach {t opts} {E0 {-elide 1} E1 {-elide 1 -undo 0} T0 {-underline 0}} {
	.t tag configure $t {*}$opts
    }
    for {set i 0} {$i < 19} {incr i 2} {
	.t tag add T0 2.[expr {10 + $i}] 2.[expr {11 + $i}]
    }
    .t edit reset
    .t tag add E0 2.5 2.10
    .t edit separator
    .t delete 2.2 2.10
    .t edit separator
    .t tag add E1 1.35 2.21
    .t edit undo
    set res [.t tag ranges E0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {2.5 2.10}

test btree-14.84 {undo of tag clear drops a non-undoable elide tag: recompute the elide info} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The clear-undo overwrites the tag sets of the restored range with the
    # recorded snapshots; an elide tag excluded from undo which was added
    # after the clear is silently dropped by that overwrite, so the elide
    # topology (switches, logicalLine flags) must be recomputed as well
    # (panic "wrong logicalLine flag").
    .t debug 1
    .t insert end "abcd\nefgh"
    .t tag configure E1 -elide 1 -undo 0
    .t tag configure T0 -underline 0
    .t edit reset
    .t tag add T0 1.2 2.2
    .t tag clear 1.2 2.2
    .t tag add E1 1.1 2.3
    .t edit undo
    set res [list [.t tag ranges E1] [.t tag ranges T0]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{1.1 1.2 2.2 2.3} {}}

test btree-14.85 {undo of tag clear drops an elide tag: switches within one line} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # Single line variant: the stale pair used to leave a misplaced
    # branch/link instead of a wrong logicalLine flag.
    .t debug 1
    .t insert end "hglaglqyvszpz"
    .t tag configure E1 -elide 1 -undo 0
    .t tag configure T0 -underline 0
    .t edit reset
    .t tag add T0 1.8 1.11
    .t tag clear 1.8 1.11
    .t tag add E1 1.6 1.11
    .t edit separator
    .t edit undo
    set res [list [.t tag ranges E1] [.t tag ranges T0]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{1.6 1.8} {}}

test btree-14.86 {tag clear: a boundary line must not reuse the other boundary's recomputed summary} -setup {
    destroy .t
    text .t -undo 0
} -body {
    # Both boundary lines share the same (tagon, tagoff) tag set objects
    # after the multiline add; the left-amputating clear recomputes line 1
    # as empty and used to serve that cached result to line 2, whose kept
    # tail still carries the tag (panic "sum of node tag information is
    # wrong (tagon)", and stale tag roots).
    .t debug 1
    .t insert end "abcdef\nbcd"
    .t tag configure T0 -underline 0
    .t tag add T0 1.3 2.2
    .t tag clear 1.1 2.1
    set res [.t tag ranges T0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {2.1 2.2}

test btree-14.87 {redo of a tag clear after redo of the add re-aliases the boundary lines} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The interposed delete/undo de-aliases the boundary lines (the direct
    # clear is correct), then redo of the add aliases them again: the redo
    # of the clear replays TkBTreeClearTags and used to hit the cache.
    .t debug 1
    .t insert end "zuzewepkchcvogpjncp\nmiottabxjolkhhemgji"
    .t tag configure T0 -underline 0
    .t tag add T0 1.16 2.16
    .t edit separator
    .t delete 1.16 2.6
    .t edit separator
    .t edit undo
    .t tag clear 1.12 2.12
    .t edit separator
    .t edit undo
    .t edit undo
    .t edit redo
    .t edit redo
    set res [.t tag ranges T0]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {2.12 2.16}

test btree-14.88 {tag clear amputating an elided multiline range from the left} -setup {
    destroy .t
    text .t -undo 0
} -body {
    .t debug 1
    .t insert end "abcdef\nbcd"
    .t tag configure E0 -elide 1
    .t tag add E0 1.3 2.2
    .t tag clear 1.1 2.1
    set res [.t tag ranges E0]
    .t debug 0
