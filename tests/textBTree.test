} -result [list {1.2 2.1} "aabb\nccc" {1.2 2.1} "aabb\nccc"]

test btree-14.49 {undo multiline delete across the branch and the elided newline, -undo 0} -setup {
    destroy .t
    text .t -undo 1
} -body {
    .t debug 1
    .t insert end "aaa\nbbb\nccc"
    .t tag configure B -elide 1 -undo 0
    .t tag add B 1.2 3.1
    .t delete 1.1 2.2
