    .t compare 1.11 == 1.19
    .t tag add T1 1.11 1.19
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.2 > 1.19
    .t compare 1.2 == 1.19
    .t delete 1.2 1.19
