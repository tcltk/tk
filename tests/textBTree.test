} -result {2.1 2.2}

test btree-14.89 {restore proc: drop of a switch enrolled in two tokens leaves no dangling fork} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The first delete cuts the start of the second elided range: its branch
    # is re-added to the tree and enrolled in that token. The second delete
    # removes it again (dies in that token, stashing the link), and the
    # extending tag add annihilates the stashed link. On undo the newer
    # token drops the switch (annihilated stash) - the older token must
    # then see the annihilation marker, not a dangling fork (assert
    # "branch.nextPtr->typePtr == &tkTextLinkType").
    .t debug 1
    .t insert end "abcdefghijklmnopqrst"
    .t tag configure E0 -elide 1
    .t edit reset
    .t tag add E0 1.2 1.5
    .t tag add E0 1.8 1.12
    .t delete 1.8 1.10
    .t delete 1.4 1.9
    .t tag add E0 1.0 1.9
    .t edit undo
    set res [list [.t tag ranges E0] [.t get 1.0 end-1c]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{} abcdefghijklmnopqrst}

test btree-14.90 {elide recompute walk: a link insertion pairs with the still open kept branch} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # The undone tag clear drops the non-undoable elide tag and shrinks the
    # elided range: the recompute starts at the enclosing branch (kept), its
    # link expires within the walk, and the closing link insertion used to
    # ignore the kept branch and search from the range start - which is the
    # branch itself, not content (assert in SegmentIsElided).
    .t debug 1
    .t insert end "abcdefghijklmnopqrst"
    .t tag configure E0 -elide 1
    .t tag configure E1 -elide 1 -undo 0
    .t tag configure T0 -underline 0
    .t edit reset
    .t tag add E0 1.2 1.11
    .t tag add T0 1.11 1.14
    .t tag clear 1.6 1.14
    .t tag add E1 1.8 1.13
    .t edit undo
    set res [list [.t tag ranges E0] [.t tag ranges E1] [.t tag ranges T0]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {{} {} {}}

test btree-14.91 {elide recompute walk: link insertion search anchored on a mark range start} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # Undoing a tag remove re-adds an elide tag; the update range starts at
    # a mark (split point), and the search for the enclosing branch used to
    # be anchored on it (assert in SegmentIsElided: a mark carries no tag
    # info). The anchor must be the preceding content segment. Recorded
    # fuzz sequence (fuzz_tagops seed 878), fatal at the last undo.
    .t debug 1
    .t insert end "sughbkrsbpjybgtq\nozdyyqtdgqgflrhelddtx"
    foreach {t opts} {E0 {-elide 1} E1 {-elide 1 -undo 0}} {
	.t tag configure $t {*}$opts
    }
    .t edit reset
    .t insert 1.7 aaa
    .t edit separator
    .t tag remove E1 1.19 2.9
    .t edit separator
    .t delete 1.3 1.8
    .t edit separator
    .t tag add E0 1.2 1.14
    .t edit separator
    .t tag add E0 1.10 2.14
    .t edit separator
    .t delete 1.4 2.6
    .t edit separator
    .t tag add E0 1.3 1.12
    .t edit separator
    .t delete 1.6 1.18
    .t edit separator
    .t insert 1.7 n
    .t edit separator
    .t insert 1.1 rrr
    .t edit separator
    .t delete 1.8 1.10
    .t edit separator
    .t delete 1.1 1.9
    .t edit separator
    .t edit undo
    .t tag remove E0 1.2 1.8
    .t edit separator
    .t edit redo
    .t tag add E1 1.3 1.7
    .t edit separator
    foreach _ {1 2 3 4 5 6 7} { .t edit undo }
    set res [list [string equal [.t get 1.0 end-1c] "sughbkraaasbpjybgtq\nozdyyqtdgqgflrhelddtx"] \
	    [.t tag ranges E0] [.t tag ranges E1]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {1 {} {1.1 1.3 1.8 1.9}}

test btree-14.92 {elide walk: a removed switch must not swallow the transition} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
    # The number of displayed chars must match the elision by tags (E0/E1
    # are the only elide tags, both -elide 1, so plain range union applies).
    proc elideConsistent-14-92 {w} {
	set iv {}
	foreach t {E0 E1} {
	    foreach {a b} [$w tag ranges $t] {
		lappend iv [list [$w count -chars 1.0 $a] [$w count -chars 1.0 $b]]
	    }
	}
	set hidden 0
	set last -1
	foreach r [lsort -integer -index 0 $iv] {
	    lassign $r a b
	    if {$a < $last} { set a $last }
	    if {$b > $a} { incr hidden [expr {$b - $a}] ; set last $b }
	}
	set total [$w count -chars 1.0 end]
	expr {[$w count -displaychars 1.0 end] == $total - $hidden}
    }
} -body {
    # Undoing the delete restores the chars without their -undo 0 elide tag,
    # and the recompute finds a link where elision now starts: the walk
    # removed the link but the else-if chain swallowed the transition of the
    # content segment behind it, leaving the still elided remainder of the
    # zone without an opening branch (silent, the display shows tagged-elided
    # text) - the pending E1 close then detonates a later undo. Recorded fuzz
    # scenario (fuzz_tagops seed 969 variant, P12 detonator).
    .t debug 1
    .t insert end "lgepvgspifn\nhilnuomspypcqclcoizgbazi"
    foreach {t opts} {E0 {-elide 1} E1 {-elide 1 -undo 0} T0 {-underline 0} T1 {-undo 0 -underline 0}} {
	.t tag configure $t {*}$opts
    }
    .t edit reset
    .t tag add E0 1.0 1.1
    .t edit separator
    .t tag remove T0 1.3 1.10
    .t edit separator
    .t tag add T1 1.1 1.5
    .t edit separator
    .t tag add E0 2.7 2.15
    .t edit separator
    .t tag add E1 2.9 2.22
    .t edit separator
    .t tag add E0 1.3 1.5
    .t edit separator
    .t delete 1.1 2.22
    .t edit separator
    .t tag add T1 1.1 1.3
    .t edit separator
    .t tag add E1 1.1 1.3
    .t edit separator
    .t tag remove T1 1.1 1.3
    .t edit separator
    .t tag remove E0 1.2 1.3
    .t edit separator
    .t tag add E0 1.1 1.3
    .t edit separator
    .t edit undo
    set res [elideConsistent-14-92 .t]
    while {[.t edit canundo]} { .t edit undo }
    lappend res [string equal [.t get 1.0 end-1c] "lgepvgspifn\nhilnuomspypcqclcoizgbazi"]
    lappend res [elideConsistent-14-92 .t]
    while {[.t edit canredo]} { .t edit redo }
    while {[.t edit canundo]} { .t edit undo }
    while {[.t edit canredo]} { .t edit redo }
    lappend res [elideConsistent-14-92 .t]
    .t debug 0
    set res
} -cleanup {
    destroy .t
    rename elideConsistent-14-92 {}
} -result {1 1 1 1}

test btree-14.93 {elide walk: enforce reciprocity when the kept link claims the kept branch} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # A restored switch rewrites both directions of its old pairing and
    # steals a counterpart which the previous reconcile had re-paired. The
    # walk then met the orphaned link claiming the kept branch one-way and
    # trusted it without checking reciprocity, leaving the pairing crossed
    # (BranchCheckProc: related link is not pointing to this branch).
    # Recorded fuzz sequence (fuzz_tagops seed 99).
    .t debug on
    .t insert end ktrrfgnzkgkhlltyqizicuec
    .t tag configure E0 -elide 1
    .t tag configure E1 -elide 1 -undo 0
    .t tag configure T0 -underline 0
    .t tag configure T1 -undo 0 -underline 0
    .t edit reset
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t insert 1.10 dd
    .t edit separator
    .t edit canredo
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t insert 1.13 qqq
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.13 > 1.8
    .t compare 1.8 == 1.13
    .t tag add E1 1.8 1.13
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.5 > 1.15
    .t compare 1.5 == 1.15
    .t tag remove T0 1.5 1.15
    .t edit separator
    .t edit canredo
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.8 > 1.16
    .t compare 1.8 == 1.16
    .t tag add E0 1.8 1.16
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.4 > 1.26
    .t compare 1.4 == 1.26
    .t tag remove E0 1.4 1.26
    .t edit separator
    .t edit canredo
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.3 > 1.17
    .t compare 1.3 == 1.17
    .t tag remove T0 1.3 1.17
    .t edit separator
    .t edit canundo
    .t edit undo
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.22 > 1.8
    .t compare 1.8 == 1.22
    .t tag add E1 1.8 1.22
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.12 > 1.12
    .t compare 1.12 == 1.12
    .t edit canredo
    .t edit redo
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.11 > 1.7
    .t compare 1.7 == 1.11
    .t tag add T1 1.7 1.11
    .t edit separator
    .t index end-1c
    .t count -chars 1.0 {1.0 lineend}
    .t count -chars 1.0 {1.0 lineend}
    .t compare 1.4 > 1.28
    .t compare 1.4 == 1.28
    .t tag add E0 1.4 1.28
    .t edit separator
    .t edit canundo
    .t edit undo
    .t edit canundo
    .t edit undo
    .t edit canundo
    .t edit undo
    .t edit canundo
    .t edit canredo
    .t edit redo
    .t edit canredo
    .t edit redo
    .t edit canredo
    .t edit redo
    .t edit canredo
    set res [list [string length [.t get 1.0 end-1c]] [.t tag ranges E0] [.t tag ranges E1]]
    .t debug 0
    set res
} -cleanup {
    destroy .t
} -result {29 {1.4 1.28} {1.8 1.10 1.12 1.13 1.16 1.25}}

test btree-14.94 {elide walk: a link insertion must not silently orphan the mutual old fork} -setup {
    destroy .t
    text .t -undo 1 -autoseparators 0
} -body {
    # A link inserted by the walk re-wires the open branch away from its
    # mutual link; the orphan keeps closing an elided range ahead and must be
    # remembered for positional re-pairing (dangling), otherwise the post
    # loop pairs a pending branch with a link stolen from another mutual
    # pair (LinkCheckProc: related branch is not pointing to this link).
    # Recorded fuzz sequence (fuzz_tagops seed 683, multiline).
