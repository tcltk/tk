    } -body {
	.tv selection set {}
	.tv selection
    }

test Selection_Clear-47.3 {Multiple items} -setup {
	.tv selection set [list red green blue]
    } -body {
	.tv selection set {}
	.tv selection
    }

test Selection_Clear-47.4 {Multiple levels} -setup {
	.tv selection set [list red magenta green blue cyan]
    } -body {
	.tv selection set {}
	.tv selection
    }

