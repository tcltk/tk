	.tv focus red
	.tv focus
    } -result {red}

test Focus-24.6 {Set focus grandchild} -body {
	.tv focus maroon
	.tv focus
    } -result {maroon}

test Focus-24.7 {Clear focus} -body {
	.tv focus {}
	.tv focus
    }

test Focus-24.8 {Focus on hidden item} -setup {
	.tv hide green
    } -body {
	.tv focus green
	.tv focus
    } -result {green}

test Focus-24.9 {Delete focus item} -body {
	.tv focus blue
