# Identify
proc get_col_id {w x y} {return [$w column [$w identify column $x $y] -id]}
proc mm {pixels} {return [format "%dm" [expr {int(round(double([winfo screenmmwidth .])/double([winfo screenwidth .]) * double($pixels)))}]]}
set geometry [winfo geometry .]


test Identify-87.1 {Create} -body {
	set w [create .tv]
	fixed_table $w
	set w
    } -result {.tv}

test Identify-87.2 {Too few args} -body {
	.tv identify
    } -result {wrong # args: should be ".tv identify command x y"} -returnCodes {1}

test Identify-87.3 {Too many args} -body {
	.tv identify command x y bogus
    } -result {wrong # args: should be ".tv identify command x y"} -returnCodes {1}

test Identify-87.4 {Invalid command} -body {
	.tv identify bogus x y
    } -result {bad command "bogus": must be region, item, column, row, element, or cell} -returnCodes {1}

test Identify-87.5 {Invalid x} -body {
	.tv identify region bogus 50
    } -result {expected screen distance but got "bogus"} -returnCodes {1}

test Identify-87.6 {Invalid y} -body {
	.tv identify region 50 bogus
    } -result {expected screen distance but got "bogus"} -returnCodes {1}

test Identify-87.7 {Region Heading Columns} -body {
	list [.tv identify region 100 10] [.tv identify region 300 10] [.tv identify region 500 10] [.tv identify region 700 10]
    } -result [lrepeat 4 heading]

test Identify-87.8 {Region Heading Columns mm} -body {
	list [.tv identify region [mm 100] [mm 10]] [.tv identify region [mm 300] [mm 10]] [.tv identify region [mm 500] [mm 10]] [.tv identify region [mm 700] [mm 10]]
    } -result [lrepeat 4 heading]

test Identify-87.9 {Region Tree Rows} -body {
	list [.tv identify region 10 30] [.tv identify region 30 50] [.tv identify region 50 70] [.tv identify region 70 90]
    } -result [lrepeat 4 tree]

test Identify-87.10 {Region Tree Rows mm} -body {
	list [.tv identify region [mm 10] [mm 30]] [.tv identify region [mm 30] [mm 50]] [.tv identify region [mm 50] [mm 70]] [.tv identify region [mm 70] [mm 90]]
    } -result [lrepeat 4 tree]

test Identify-87.11 {Region Cell} -body {
	list [.tv identify region 100 30] [.tv identify region 300 50] [.tv identify region 500 70] [.tv identify region 700 90]
    } -result {tree cell cell cell}

test Identify-87.12 {Region Cell mm} -body {
	list [.tv identify region [mm 100] [mm 30]] [.tv identify region [mm 300] [mm 50]] [.tv identify region [mm 500] [mm 70]] [.tv identify region [mm 700] [mm 90]]
    } -result {tree cell cell cell}

test Identify-87.13 {Region Separator} -body {
	.tv identify region [.tv column #0 -width] 5
    } -result {separator}

test Identify-87.14 {Region Out of Range} -body {
	.tv identify region 900 900
    } -result {nothing}

test Identify-87.15 {Item Header} -body {
	.tv identify item 100 10
    }

test Identify-87.16 {Items} -body {
	list [.tv identify item 100 25] [.tv identify item 300 45] [.tv identify item 500 65] [.tv identify item 700 85]
    } -result {red pink maroon darkred}

test Identify-87.17 {Items mm} -body {
	list [.tv identify item [mm 100] [mm 30]] [.tv identify item [mm 300] [mm 50]] [.tv identify item [mm 500] [mm 70]] [.tv identify item [mm 700] [mm 90]]
    } -result {red pink maroon darkred}

test Identify-87.18 {Item Out of Range} -body {
	.tv identify item 1000 110
    } -result {magenta}

test Identify-87.19 {Column Header} -body {
	get_col_id .tv 100 10
    } -result {#0}

test Identify-87.20 {Columns} -body {
	list [get_col_id .tv 100 30] [get_col_id .tv 300 50] [get_col_id .tv 500 70] [get_col_id .tv 700 90]
    } -result {{#0} Hex Decimal Float}

test Identify-87.21 {Columns mm} -body {
	list [get_col_id .tv [mm 100] [mm 30]] [get_col_id .tv [mm 300] [mm 50]] [get_col_id .tv [mm 500] [mm 70]] [get_col_id .tv [mm 700] [mm 90]]
    } -result {{#0} Hex Decimal Float}

test Identify-87.22 {Column Out of Range} -body {
	.tv identify column 900 110
    }

test Identify-87.23 {Cell Header} -body {
	.tv identify cell 100 10
    }

test Identify-87.24 {Cells} -body {
	list [.tv identify cell 100 30] [.tv identify cell 300 50] [.tv identify cell 500 70] [.tv identify cell 700 90]
    } -result {{red #0} {pink #1} {maroon #2} {darkred #3}}

test Identify-87.25 {Cells mm} -body {
	list [.tv identify cell [mm 100] [mm 30]] [.tv identify cell [mm 300] [mm 50]] [.tv identify cell [mm 500] [mm 70]] [.tv identify cell [mm 700] [mm 90]]
    } -result {{red #0} {pink #1} {maroon #2} {darkred #3}}

test Identify-87.26 {Cell Out of Range} -body {
	.tv identify cell 900 110
    }
# Header elements are not reported

test Identify-87.27 {Element Header} -body {
	list [.tv identify element 100 10] [.tv identify element 300 10] [.tv identify element 500 10] [.tv identify element 700 10]
    } -result [lrepeat 4 {}]

test Identify-87.28 {Element Padding} -body {
	list [.tv identify element 50 30] [.tv identify element 70 50] [.tv identify element 90 70] [.tv identify element 110 90]
    } -result [lrepeat 4 padding]

test Identify-87.29 {Element Padding mm} -body {
	list [.tv identify element 30m [mm 30]] [.tv identify element 40m [mm 50]] [.tv identify element 40m [mm 70]] [.tv identify element 40m [mm 90]]
    } -result [lrepeat 4 padding]

test Identify-87.30 {Element Indicator} -body {
	list [.tv identify element 15 30] [.tv identify element 25 50] [.tv identify element 25 70] [.tv identify element 25 90]
    } -result [lrepeat 4 Treeitem.indicator]

test Identify-87.31 {Element Indicator mm} -body {
	list [.tv identify element 3m [mm 30]] [.tv identify element 7m [mm 50]] [.tv identify element 7m [mm 70]] [.tv identify element 7m [mm 90]]
    } -cleanup {
	.tv expand -recurse {}
	update
    } -result [lrepeat 4 Treeitem.indicator]

test Identify-87.32 {Element Text} -body {
	list [.tv identify element 20 30] [.tv identify element 40 50] [.tv identify element 45 70] [.tv identify element 45 90]
    } -result [lrepeat 4 text]

test Identify-87.33 {Element Text mm} -body {
	list [.tv identify element 7m [mm 30]] [.tv identify element 15m [mm 50]] [.tv identify element 15m [mm 70]] [.tv identify element 15m [mm 90]]
    } -result [lrepeat 4 text]

test Identify-87.34 {Element Out of Range} -body {
	.tv identify element 900 900
    }

test Identify-87.35 {Row} -body {
	.tv identify row 300 50
    } -result {pink}

test Identify-87.36 {Reverse display order} -setup {
	.tv configure -displaycolumns [list 2 1 0]
	update idletasks
    } -body {
	list [get_col_id .tv 100 30] [get_col_id .tv 300 50] [get_col_id .tv 500 70] [get_col_id .tv 700 90]
    } -result {{#0} Float Decimal Hex}

test Identify-87.37 {Identify Columns mm} -body {
	list [get_col_id .tv [mm 100] [mm 30]] [get_col_id .tv [mm 300] [mm 50]] [get_col_id .tv [mm 500] [mm 70]] [get_col_id .tv [mm 700] [mm 90]]
    } -cleanup {
	.tv configure -displaycolumns {#all}
	update idletasks
    } -result {{#0} Float Decimal Hex}

test Identify-87.38 {Identify Scrolled Columns Bug #2381555} -setup {
	fixed_cols .tv
	.tv xview 200
	update
    } -body {
	list [get_col_id .tv 100 30] [get_col_id .tv 300 50] [get_col_id .tv 500 70] [get_col_id .tv 700 90]
    } -result {{#0} Hex Decimal Float}

test Identify-87.39 {Identify Scrolled Cells Bug #2381555} -body {
	list [.tv identify cell 100 30] [.tv identify cell 300 50] [.tv identify cell 500 70] [.tv identify cell 700 90]
    } -cleanup {
	.tv xview 0
	wm geometry . $geometry
	update
    } -result {{red #0} {pink #1} {maroon #2} {darkred #3}}

test Identify-87.40 {No tree column} -setup {
	.tv configure -show {headings}
	update idletasks
    } -body {
	.tv identify region 10 30
    } -result {cell}

test Identify-87.41 {No tree column and reverse display order} -setup {
	.tv configure -displaycolumns [list 2 1 0]
	update idletasks
    } -body {
	list [get_col_id .tv 100 30] [get_col_id .tv 300 50] [get_col_id .tv 500 50]
    } -cleanup {
	.tv configure -displaycolumns {}
    } -result {Float Decimal Hex}

test Identify-87.42 {Cleanup} -setup {
	wm geometry . $geometry
    } -body {
	destroy .tv .sx .sy
    }

# Style


test Row_Height-88.1 {Create} -body {
	set w [create .tv]
	fixed_table $w
	set w
    } -result {.tv}

test Row_Height-88.2 {Rowheight 0 Bug #6ee162c3d9} -body {
	ttk::style configure Treeview -rowheight 0
	ttk::style configure Treeview -rowheight
    } -cleanup {
	ttk::style configure Treeview -rowheight 20
    } -result {0}

test Row_Height-88.3 {Item font change does not resize rows} -body {
	ttk::style configure Treeview -font "Helvetica 24"
	update
	lindex [.tv bbox red 0] 3
    } -result {20}

test Row_Height-88.4 {Named font change doesn't change row height down} -setup {
	font create __tf -family Courier -size 12
    } -body {
	ttk::style configure Treeview -font __tf
	update
	lindex [.tv bbox red 0] 3
    } -result {20}

test Row_Height-88.5 {Named font change doesn't change row height up} -setup {
	font configure __tf -family Helvetica -size 24
    } -body {
	ttk::style configure Treeview -font __tf
	update
	lindex [.tv bbox red 0] 3
    } -cleanup {
	font delete __tf
    } -result {20}

test Row_Height-88.6 {Change height to 73 pixels} -body {
	ttk::style configure Treeview -rowheight 73
	update
	lindex [.tv bbox red 0] 3
    } -result {73}

test Row_Height-88.7 {Change height to 25 pixels} -body {
	ttk::style configure Treeview -rowheight 25
	update
	lindex [.tv bbox red 0] 3
    } -cleanup {
	ttk::style configure Treeview -rowheight 20
    } -result {25}

test Row_Height-88.8 {Heading font change resizes header} -body {
	set h [lindex [.tv bbox red] 1]
	ttk::style configure Treeview.Heading -font {Arial 32}
	update
	expr {$h < [lindex [.tv bbox red] 1]}
    } -result {1}

test Row_Height-88.9 {Cleanup} -body {
	destroy .tv .sx .sy
    }

test Row_Height-88.10 {Create} -body {
	set w [create .tv]
	fixed_table .tv
	set w
    } -result {.tv}

test Row_Height-88.11 {Item Padding 1} -body {
	ttk::style configure Item -padding {2 2 2 2}
	update
	ttk::style configure Item -padding
    } -cleanup {
	ttk::style configure Item -padding {}
    } -result {2 2 2 2}

test Row_Height-88.12 {Item Padding 2} -body {
	ttk::style configure Item -padding {2 3 2 5}
	update
	lindex [.tv bbox red 0] 3
    } -cleanup {
	ttk::style configure Item -padding {}
    } -result {20}

test Row_Height-88.13 {Cell Padding 1} -body {
	ttk::style configure Cell -padding {2 5 2 5}
	update
	ttk::style configure Cell -padding
    } -cleanup {
	ttk::style configure Cell -padding {}
    } -result {2 5 2 5}

test Row_Height-88.14 {Cell Padding 2} -body {
	ttk::style configure Cell -padding {2 8 2 9}
	update
	lindex [.tv bbox red 0] 3
    } -cleanup {
	ttk::style configure Cell -padding {}
    } -result {20}

test Row_Height-88.15 {Cleanup} -body {
	destroy .tv .sx .sy
    }

# Cleanup
::tcltest::cleanupTests
return
