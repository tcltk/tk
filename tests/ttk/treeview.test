	.tv tag add foo gray
	.tv item gray -tags
    } -result {foo}

test Tag_Add-72.10 {Tag add remove no -tags bug #3085489} -body {
	.tv tag remove foo gray
	.tv item gray -tags
    }

test Tag_Add-72.11 {Cleanup} -body {
	destroy .tv .sx .sy
    }

# Tag bind
proc cellEvent {w item col} {lassign [$w bbox $item $col] aX aY aW aH;set aX [expr {$aX + $aW / 2}];set aY [expr {$aY + $aH / 2}];event generate $w <Button-1> -x $aX -y $aY}


test Tag_Bind-73.1 {Init} -body {
	set w [create .tv]
    } -result {.tv}

test Tag_Bind-73.2 {Too few args} -body {
	.tv tag bind
    } -result {wrong # args: should be ".tv tag bind tagName ?sequence? ?script?"} -returnCodes {1}

test Tag_Bind-73.3 {Too many args} -body {
	.tv tag bind tagName sequence script bogus
    } -result {wrong # args: should be ".tv tag bind tagName ?sequence? ?script?"} -returnCodes {1}

test Tag_Bind-73.4 {Invalid tag name} -body {
	.tv tag bind newTag
    }

test Tag_Bind-73.5 {Create tag name} -body {
	.tv tag configure newTag
	.tv tag names
    } -result {newTag}

test Tag_Bind-73.6 {Set binding for sequence} -body {
	.tv tag bind newTag <Control-q> [list test script]
    }

test Tag_Bind-73.7 {Set binding for invalid sequence} -body {
	.tv tag bind newTag <Configure> [list test script]
    } -match {glob} -result {unsupported event <Configure>
only key, button, motion, enter, leave, and virtual events supported} -returnCodes {1}

test Tag_Bind-73.8 {Get binding for sequence} -body {
	.tv tag bind newTag <Control-q>
    } -result {test script}

test Tag_Bind-73.9 {Get binding for invalid sequence} -body {
	.tv tag bind newTag <Control-Q>
    }

test Tag_Bind-73.10 {Get all bindings for tag} -body {
	.tv tag bind newTag
    } -result {<Control-Key-q>}

test Tag_Bind-73.11 {Delete tag} -body {
	.tv tag delete newTag
	.tv tag bind newTag
    }

test Tag_Bind-73.12 {Null binding bug #3006842} -body {
	.tv tag bind empty <Button-1> {}
	.tv insert {} end -text "Click me" -tags empty
	event generate .tv <Button-1> -x 10 -y 10
	.tv tag bind empty
    }

test Tag_Bind-73.13 {Init} -body {
	.tv tag configure t1 -background red
	.tv tag configure t2 -background blue
	.tv tag add t1 red
	.tv tag cell add t2 {red Hex}
	.tv tag cell add t2 {pink Hex}
	set ::tagtest {}
	.tv tag bind t1 <Button-1> {lappend ::tagtest t1}
	.tv tag bind t2 <Button-1> {lappend ::tagtest t2}
    }

test Tag_Bind-73.14 {Item tag test} -body {
	cellEvent .tv red #0
	set ::tagtest
    } -cleanup {
	set ::tagtest {}
    } -result {t1}

test Tag_Bind-73.15 {Cell tag test} -body {
	cellEvent .tv pink Hex
	set ::tagtest
    } -cleanup {
	set ::tagtest {}
    } -result {t2}

test Tag_Bind-73.16 {Item and cell tags test} -body {
	cellEvent .tv red Hex
	set ::tagtest
    } -cleanup {
	set ::tagtest {}
    } -result {t1 t2}

test Tag_Bind-73.17 {Cleanup} -setup {
	rename cellEvent {}
    } -body {
	destroy .tv .sx .sy
    }

