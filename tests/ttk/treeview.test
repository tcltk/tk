	destroy .tv
    }

# Focus Ring


test Focus_Ring-6.1 {Create} -body {
	set w [ttk::treeview .tv -columns {Data}]
	grid $w
	$w insert {} end -id red -text "Test" -values Data
	$w heading #0 -text Tree
	$w heading #1 -text Data
	set w
    } -result {.tv}

test Focus_Ring-6.2 {Thick focus ring} -body {
	set h [lindex [.tv bbox red] 3]
	ttk::style configure Row -focuscolor green -focussolid 1 -focusthickness 3
	$w focus red
	list $h [lindex [.tv bbox red] 3]
    } -result {17 17}

test Focus_Ring-6.3 {Dotted focus ring} -body {
	set h [lindex [.tv bbox red] 3]
	ttk::style configure Row -focuscolor black -focussolid 0 -focusthickness 1
	$w focus red
	list $h [lindex [.tv bbox red] 3]
    } -result {17 17}

test Focus_Ring-6.4 {Row padding} -body {
	set h [lindex [.tv bbox red] 3]
	ttk::style configure Row -focuscolor black -focussolid 1 -focusthickness 1 -padding {2 3 2 3}
	$w focus red
	list $h [lindex [.tv bbox red] 3]
    } -cleanup {
	$w focus {}
    } -result {17 17}

test Focus_Ring-6.5 {Cell focus} -body {
	set h [lindex [.tv bbox red #1] 3]
	ttk::style configure Row -focuscolor green -focussolid 1 -focusthickness 3
	$w cellfocus [list red #1]
	list $h [lindex [.tv bbox red #1] 3]
    } -result {17 17}

test Focus_Ring-6.6 {Cell dotted focus} -body {
	set h [lindex [.tv bbox red #1] 3]
	ttk::style configure Row -focuscolor black -focussolid 0 -focusthickness 1
	$w cellfocus [list red #1]
	list $h [lindex [.tv bbox red #1] 3]
    } -cleanup {
	ttk::style configure Row -focuscolor black -focussolid 1 -focusthickness 1
    } -result {17 17}

test Focus_Ring-6.7 {Cell padding} -body {
	set h [lindex [.tv bbox red #1] 3]
	ttk::style configure Cell -padding {2 3 2 3}
	$w focus red
	list $h [lindex [.tv bbox red] 3]
    } -cleanup {
	ttk::style configure Cell -padding {}
    } -result {17 17}

test Focus_Ring-6.8 {Cleanup} -body {
	destroy $w
    }

