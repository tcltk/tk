	.tv search {} -all -nocase -glob -recurse -cell -start {blue Hex} -wrap *b*
    } -result {{mediumblue #0} {darkblue #0} {darkblue Hex} {brown #0} {wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex} {blue #0}}

