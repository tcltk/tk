	.tv tag bind newTag <Control-q> [list test script]
    }

test Tag_Bind-77.7 {Set binding for invalid sequence} -body {
	.tv tag bind newTag <Configure> [list test script]
    } -result {unsupported event <Configure>
only key, button, motion, and virtual events supported} -returnCodes {1}

