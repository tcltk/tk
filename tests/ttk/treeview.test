# Selection Remove


test Selection_Remove-52.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Selection_Remove-52.2 {Too few args} -body {
	.tv selection remove
    } -result {wrong # args: should be ".tv selection remove ?items?|?options first last?"} -returnCodes {1}

test Selection_Remove-52.3 {Too many args} -body {
	.tv selection remove -arg1 -arg2 first last bogus
    } -result {wrong # args: should be ".tv selection remove ?items?|?options first last?"} -returnCodes {1}

test Selection_Remove-52.4 {Invalid item} -body {
	.tv selection remove bogus
    } -result {Item bogus not found} -returnCodes {1}

test Selection_Remove-52.5 {Root item} -body {
	.tv selection remove {}
    }

test Selection_Remove-52.6 {Single item} -setup {
	.tv selection set red
    } -body {
	.tv selection remove red
	.tv selection
    }

test Selection_Remove-52.7 {Empty List} -setup {
	.tv selection set blue
    } -body {
	.tv selection remove [list]
	.tv selection
    } -cleanup {
	.tv selection set {}
    } -result {blue}

test Selection_Remove-52.8 {Multiple items} -setup {
	.tv selection set [list red green blue black white]
    } -body {
	.tv selection remove [list red green blue black white]
	.tv selection
    }

test Selection_Remove-52.9 {Multiple levels} -setup {
	.tv selection set [list red green blue maroon cyan]
    } -body {
	.tv selection remove [list red green blue maroon cyan]
	.tv selection
    }

test Selection_Remove-52.10 {Some selected items} -setup {
	.tv selection set [list red green blue]
    } -body {
	.tv selection remove [list red blue]
	.tv selection
    } -cleanup {
	.tv selection set {}
    } -result {green}

test Selection_Remove-52.11 {More than selected items} -setup {
	.tv selection set [list red green blue]
    } -body {
	.tv selection remove [list red green blue orange yellow]
	.tv selection
    }

test Selection_Remove-52.12 {Unselected item} -body {
	.tv selection remove red
	.tv selection
    }

test Selection_Remove-52.13 {Range of items} -setup {
	.tv selection set [list red green blue orange yellow]
    } -body {
	.tv selection remove red orange
	.tv selection
    } -result {yellow}

test Selection_Remove-52.14 {Range reverse order} -setup {
	.tv selection set [list red green blue orange yellow]
    } -body {
	.tv selection remove orange red
	.tv selection
    } -result {yellow}

test Selection_Remove-52.15 {Duplicate Items} -setup {
	.tv selection set [list red green blue orange yellow]
    } -body {
	.tv selection remove [list red green blue orange yellow red green blue orange yellow]
	.tv selection
    }

test Selection_Remove-52.16 {No Closed items} -setup {
	.tv item green -open 0 -hidden 0
	.tv selection set [list green lime teal]
    } -body {
	.tv selection remove -nohidden -recurse red blue
	.tv selection
    } -result {lime teal}

test Selection_Remove-52.17 {Include Closed items} -setup {
	.tv item green -open 0 -hidden 0
	.tv selection set [list green lime teal]
    } -body {
	.tv selection remove -hidden -recurse red blue
	.tv selection
    }

test Selection_Remove-52.18 {No Hidden items} -setup {
	.tv item green -open 1 -hidden 1
	.tv selection set [list green lime teal]
    } -body {
	.tv selection remove -nohidden -recurse red blue
	.tv selection
    } -result {green lime teal}

test Selection_Remove-52.19 {Include Hidden items} -setup {
	.tv item green -open 1 -hidden 1
	.tv selection set [list green lime teal]
    } -body {
	.tv selection remove -hidden -recurse red blue
	.tv selection
    }

test Selection_Remove-52.20 {No Recurse} -setup {
	.tv item green -open 1 -hidden 1
	.tv selection set [list green lime teal]
    } -body {
	.tv selection remove -nohidden -norecurse red blue
	.tv selection
    } -result {green lime teal}

test Selection_Remove-52.21 {Include Recurse items} -setup {
	.tv item green -open 1 -hidden 1
	.tv selection set [list green lime teal]
    } -body {
	.tv selection remove -hidden -norecurse red blue
	.tv selection
    } -result {lime teal}

test Selection_Remove-52.22 {Cleanup} -body {
	destroy .tv .sx .sy
    }

