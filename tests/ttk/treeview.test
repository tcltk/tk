# See
proc xdelta {w item column} {
    set x [lindex [$w xview] 0]
    $w see $item $column
    set delta [expr {[lindex [$w xview] 0] - $x}]
    expr {$delta > 0 ? 1 : ($delta < 0 ? -1 : 0)}
}
proc ydelta {w item} {
    set y [lindex [$w yview] 0]
    $w see $item
    set delta [expr {[lindex [$w yview] 0] - $y}]
    expr {$delta > 0 ? 1 : ($delta < 0 ? -1 : 0)}
}


