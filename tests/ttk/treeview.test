	.tv search {} -all -nocase -glob -recurse -cell -start {brown Float} -stop {orange #0} -wrap *b*
    } -result {{wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex}}

test Search-69.83 {All Cells in Same Item} -body {
	.tv search {} -all -nocase -glob -recurse -cell -start {darkblue #0} -stop {darkblue Float} -wrap *b*
    } -result {{darkblue #0} {darkblue Hex}}

test Search-69.84 {All Cells in Same Item Reverse Order} -body {
	.tv search {} -all -nocase -glob -recurse -cell -start {darkblue Float} -stop {darkblue #0} -wrap -backwards *b*
    } -result {{darkblue Hex} {darkblue #0}}

