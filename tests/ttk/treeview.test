	.tv search {} -all -nocase -glob -recurse -cell -start {blue Hex} -wrap -backwards *b*
    } -result {{blue #0} {darkred Hex} {pink Hex} {beige #0} {black #0} {wheat Hex} {brown #0} {darkblue Hex} {darkblue #0} {mediumblue #0}}

test Search-69.89 {Search Setup} -body {
	set children [.tv children {}]
	.tv unhide -recurse {}
    }

test Search-69.90 {In Child} -setup {
	.tv children {} $children
    } -body {
	.tv search blue -all -glob *n*
    } -result {cyan}

test Search-69.91 {In Child No Case} -setup {
	.tv children {} $children
    } -body {
	.tv search blue -all -glob -nocase *n*
    } -result {cyan navy}

test Search-69.92 {No match} -setup {
	.tv children {} $children
    } -body {
	.tv search {} bogus
    }

test Search-69.93 {Childless Item} -setup {
	.tv children {} $children
    } -body {
	.tv search black -glob *
    }

test Search-69.94 {No Columns But Have #0} -setup {
	.tv children {} $children
	.tv configure -columns {}
    } -body {
	.tv search {} Black
    } -result {black}

test Search-69.95 {No Columns and No #0} -setup {
	.tv children {} $children
	.tv configure -columns {} -show headings
    } -body {
	.tv search {} Black
    }

test Search-69.96 {Empty tree} -setup {
	.tv children {} {}
	.tv configure -columns {} -show headings
    } -body {
	.tv search {} bogus
    }

test Search-69.97 {Cleanup} -body {
	destroy .tv .sx .sy
    }

proc sortBySize {first second} {return [expr {[string length $first] - [string length $second]}]}

