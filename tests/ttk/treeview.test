	.tv tag delete newTag
	.tv tag bind newTag
    }

test Tag_Bind-77.12 {Null binding bug #3006842} -body {
	.tv tag bind empty <Button-1> {}
	.tv insert {} end -text "Click me" -tags empty
	event generate .tv <Button-1> -x 10 -y 10
	.tv tag bind empty
    }

test Tag_Bind-77.13 {Init} -body {
	.tv tag configure t1 -background red
	.tv tag configure t2 -background blue
	.tv tag add t1 red
	.tv tag cell add t2 {red Hex}
	.tv tag cell add t2 {pink Hex}
	set ::tagtest {}
	.tv tag bind t1 <Button-1> {lappend ::tagtest t1}
	.tv tag bind t2 <Button-1> {lappend ::tagtest t2}
    }

test Tag_Bind-77.14 {Item tag test} -body {
	cellEvent .tv red #0
	set ::tagtest
    } -cleanup {
	set ::tagtest {}
    } -result {t1}

test Tag_Bind-77.15 {Cell tag test} -body {
	cellEvent .tv pink Hex
	set ::tagtest
    } -cleanup {
	set ::tagtest {}
    } -result {t2}

test Tag_Bind-77.16 {Item and cell tags test} -body {
	cellEvent .tv red Hex
	set ::tagtest
    } -cleanup {
	set ::tagtest {}
    } -result {t1 t2}

test Tag_Bind-77.17 {Cleanup} -setup {
	rename cellEvent {}
    } -body {
	destroy .tv .sx .sy
    }

