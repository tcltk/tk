    }

test Drag_and_Drop-13.14 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Drag_and_Drop-13.15 {Drag beyond right edge is allowed bug #ce470f20fd} -body {
	set res [list [.tv column #0 -width]]
	.tv drag #0 1000
	lappend res [.tv column #0 -width]
	set res
    } -cleanup {
	fixed_cols .tv
	update
    } -result {200 999}

test Drag_and_Drop-13.16 {Shrink non stretch columns so stretch fills gap bug #ce470f20fd} -setup {
	foreach col [list #0 Hex Decimal Float] {.tv column $col -width 50}
	update
    } -body {
	set width [.tv column Hex -width]
	.tv column Hex -stretch 1
	update
	list $width [.tv column Hex -width]
    } -cleanup {
	fixed_cols .tv
	update
    } -result {50 233}

test Drag_and_Drop-13.17 {Stretch column shrinks after order change bug #ce470f20fd} -setup {
	.tv configure -displaycolumns {Float Hex}
	.tv column Float -width 50
	.tv column Hex -width 50
	update
    } -body {
	set width [.tv column Hex -width]
	.tv column Hex -stretch 1
	update
	list $width [.tv column Hex -width]
    } -cleanup {
	fixed_cols .tv
	update
    } -result {50 133}

test Drag_and_Drop-13.18 {Treeview width change shrinks slack column bug #ce470f20fd} -setup {
	.tv configure -displaycolumns {Float Hex}
	.tv column Hex -width 50
	.tv column Decimal -width 60
	update
    } -body {
	set width [winfo width .tv]
	.tv column Decimal -stretch 1
	.tv configure -displaycolumns {Float Hex Decimal}
	update
	list $width [winfo width .tv]
    } -cleanup {
	fixed_cols .tv
	update
    } -result {385 385}

test Drag_and_Drop-13.19 {Cleanup} -setup {
	wm geometry . $geometry
    } -body {
	destroy .tv .sx .sy
    }


# Item functions

# Bbox
proc cell_bbox {w item} {set res [list];foreach col [concat #0 [$w cget -columns]] {lappend res [.tv bbox $item $col]};return $res}


test Bbox-14.1 {Create} -body {
	set w [create .tv]
	fixed_table $w
	. configure -width 600
	set w
    } -result {.tv}
set geometry [winfo geometry .]

test Bbox-14.2 {Too few args} -body {
	.tv bbox
    } -result {wrong # args: should be ".tv bbox item ?column?"} -returnCodes {1}

test Bbox-14.3 {Too many args} -body {
	.tv bbox item column bogus
    } -result {wrong # args: should be ".tv bbox item ?column?"} -returnCodes {1}

test Bbox-14.4 {Invalid item} -body {
	.tv bbox bogus
    } -result {Item bogus not found} -returnCodes {1}

test Bbox-14.5 {Invalid column} -body {
	.tv bbox red bogus
    } -result {Invalid column index "bogus"} -returnCodes {1}

