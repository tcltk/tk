test Bbox-9.18 {Title Columns Scroll} -setup {
	.tv configure -titlecolumns 1
	.tv xview 0
	update
    } -body {
	set res [list [cell_bbox .tv blue]]
	.tv xview 400
	update
	lappend res [cell_bbox .tv blue]
	return $res
    } -match {glob} -result {{{0 22? 200 20} {200 22? 200 20} {400 22? 200 20} {600 22? 200 20}} {{0 22? 200 20} {-200 22? 200 20} {0 22? 200 20} {200 22? 200 20}}}

test Bbox-9.19 {Title Rows No Scroll} -setup {
	.tv configure -titleitems 1
	.tv yview 0
	update
    } -body {
	set res [list [cell_bbox .tv red]]
	.tv yview 400
	update
	
	lappend res [cell_bbox .tv red]
	return $res
    } -match {glob} -result {{{0 2? 200 20} {-200 2? 200 20} {0 2? 200 20} {200 2? 200 20}} {{0 2? 200 20} {-200 2? 200 20} {0 2? 200 20} {200 2? 200 20}}}

test Bbox-9.20 {Title Rows Scroll} -setup {
	.tv configure -titleitems 1
	.tv yview 0
	update
    } -body {
	set res [list [cell_bbox .tv blue]]
	.tv yview 400
	update
	lappend res [cell_bbox .tv blue]
	return $res
    } -match {glob} -result {{{0 22? 200 20} {-200 22? 200 20} {0 22? 200 20} {200 22? 200 20}} {{} {} {} {}}}

test Bbox-9.21 {Title Columns > Number of Columns} -setup {
	.tv configure -titlecolumns 5
	.tv yview 0
	update
    } -body {
	set res [list [.tv yview]]
	.tv yview 250
	lappend res [.tv yview]
	return $res
    } -match {glob} -result {{0.0 0.46*} {0.53* 1.0}}

test Bbox-9.22 {Title Rows > Number of Items} -setup {
	.tv configure -titleitems 50
	.tv xview 0
	update
    } -body {
	set res [list [.tv xview]]
	.tv xview 250
	lappend res [.tv xview]
	return $res
    } -result {{0.0 1.0} {0.0 1.0}}


test BBox-10.1 {Cleanup} -body {
	destroy .tv .sx .sy
    }

# Children


test Children-11.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Children-11.2 {Too few args} -body {
	.tv children
    } -result {wrong # args: should be ".tv children item ?newchildren?"} -returnCodes {1}

test Children-11.3 {Too many args} -body {
	.tv children item list bogus
    } -result {wrong # args: should be ".tv children item ?newchildren?"} -returnCodes {1}

test Children-11.4 {Invalid item} -body {
	.tv children bogus
    } -result {Item bogus not found} -returnCodes {1}

test Children-11.5 {Invalid children} -body {
	.tv children {} bogus
    } -result {Item bogus not found} -returnCodes {1}

test Children-11.6 {Get children} -body {
	set children [.tv children {}]
    } -result {red green blue orange yellow purple brown black white gray}

test Children-11.7 {Get Root} -body {
	llength [.tv children {}]
    } -result {10}

test Children-11.8 {Set Root} -body {
	set l [lreverse [.tv children {}]]
	.tv children {} $l
	lcompare $l [.tv children {}]
    } -result {1}

test Children-11.9 {Get Children} -body {
	.tv children red
    } -result [lindex $::colors 1]

test Children-11.10 {Set Children} -body {
	set l [lreverse [.tv children red]]
	.tv children red $l
	lcompare $l [.tv children red]
    } -result {1}

test Children-11.11 {Replace Children} -body {
	.tv children blue green
    }

test Children-11.12 {Check Children} -body {
	expr {"green" in [.tv children blue]}
    } -result {1}

test Children-11.13 {Get Grand Children} -body {
	.tv children green
    } -result [lindex $::colors 3]

test Children-11.14 {Does not have} -body {
	.tv children green [list lime olive]
	.tv detached teal
    } -result {1}

test Children-11.15 {Replace Detached Children} -body {
	.tv children blue [lindex $::colors 5]
	.tv children blue
    } -result [lindex $::colors 5]

test Children-11.16 {Replace children with parent} -body {
	.tv children cyan [list blue]
    } -result {Cannot insert blue as descendant of cyan} -returnCodes {1}

test Children-11.17 {Replace with self} -body {
	.tv children blue [list blue]
    } -result {Cannot insert blue as descendant of blue} -returnCodes {1}

test Children-11.18 {Check Order} -body {
	checkorder {}
    } -result {1}

test Children-11.19 {Insert root item} -body {
	.tv children blue [list cyan {} darkblue]
    } -result {Cannot insert root as child item} -returnCodes {1}

test Children-11.20 {Selected item} -setup {
	.tv selection set yellow
	set children [.tv children {}]
    } -body {
	set r [.tv selection]
	.tv children {} [list red green blue]
	lappend r [.tv selection]
    } -cleanup {
	.tv children {} $children
    } -result {yellow {}}

test Children-11.21 {Focus item} -setup {
	.tv focus yellow
	set children [.tv children {}]
    } -body {
	set r [.tv focus]
	.tv children {} [list red green blue]
	lappend r [.tv focus]
    } -cleanup {
	.tv children {} $children
    } -result {yellow {}}

test Children-11.22 {Selection anchor} -setup {
	.tv selection anchor yellow
	set children [.tv children {}]
    } -body {
	set r [.tv selection anchor]
	.tv children {} [list red green blue]
	lappend r [.tv selection anchor]
    } -cleanup {
	.tv children {} $children
    } -result {yellow {}}

test Children-11.23 {Detached Item} -setup {
	.tv detach white
    } -body {
	llength [.tv children white]
    } -result {1}

test Children-11.24 {Duplicate Items} -setup {
	.tv children {} $children
    } -body {
	.tv children {} [list red green blue yellow black gray white red green blue]
	llength [.tv children {}]
    } -result {7}

test Children-11.25 {Duplicate Detached Items} -setup {
	.tv children {} $children
	.tv detach [list black white]
    } -body {
	.tv children {} [concat [.tv children {}] [.tv detached] [.tv detached]]
	llength [.tv children {}]
    } -result {12}

test Children-11.26 {Duplicate Sequential Items} -setup {
	.tv children {} $children
    } -body {
	.tv children {} [list red red green green blue blue yellow black black gray gray white]
	llength [.tv children {}]
    } -result {7}

test Children-11.27 {Cleanup} -body {
	destroy .tv .sx .sy
    }

