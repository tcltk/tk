	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {0}

test Row-8.6 {Set Item padding changes height} -body {
	set h [$w cget -rowheight]
	ttk::style configure Item -padding "2 2 2 2"
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {1}

test Row-8.7 {Change Item padding changes height} -body {
	set h [$w cget -rowheight]
	ttk::style configure Item -padding "2 3 2 5"
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -cleanup {
	ttk::style configure Item -padding {}
    } -result {1}

test Row-8.8 {Set Cell padding changes height} -body {
	set h [$w cget -rowheight]
	ttk::style configure Cell -padding "2 5 2 5"
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {1}

test Row-8.9 {Change Cell padding changes height} -body {
	set h [$w cget -rowheight]
	ttk::style configure Cell -padding "2 8 2 9"
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -cleanup {
	ttk::style configure Cell -padding {}
    } -result {1}

test Row-8.10 {Manual set row height} -body {
	set h [$w cget -rowheight]
	$w configure -rowheight 30
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {0}

test Row-8.11 {Set row height to 0 Bug #6ee162c3d9} -body {
	set h [$w cget -rowheight]
	$w configure -rowheight 0
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {0}

test Row-8.12 {Override row height set} -body {
	set h [$w cget -rowheight]
	ttk::style configure Treeview -rowheight 73
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {1}

test Row-8.13 {Override row height reset} -body {
	set h [$w cget -rowheight]
	ttk::style configure Treeview -rowheight 25
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {0}

test Row-8.14 {Override row height clear} -body {
	set h [$w cget -rowheight]
	ttk::style configure Treeview -rowheight 0
	update
	update idletasks
	expr {[lindex [.tv bbox red #1] 3] > $h}
    } -result {0}

test Row-8.15 {Cleanup} -body {
	destroy $w
	font delete TestFont
    } -cleanup {
	ttk::style configure Treeview -rowheight 0
    }

proc scrollcallback {args} {set ::scrolldata $args}

