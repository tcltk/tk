# Auto generated test cases for treeview.csv

# Load Tcl Test package
if {[lsearch [namespace children] ::tcltest] == -1} {
	package require tcltest
	namespace import ::tcltest::*
}

set ::auto_path [concat [list [file dirname [file dirname [info script]]]] $::auto_path]

package require Tk

# Constraints
ttk::style theme use default
#ttk::setTheme default
set dfont [font configure TkDefaultFont]
set hfont [font configure TkHeadingFont]
set size [expr {[tk windowingsystem] ne "aqua" ? 9 : 10}]
font configure TkDefaultFont -family Arial -size $size
font configure TkHeadingFont -family Arial -size $size

# Helper functions
set colors [list red {pink maroon darkred magenta} green {chartreuse lime olive teal} blue {cyan turquoise mediumblue darkblue navy} orange {coral} yellow {gold} purple {} brown {wheat khaki} black {} white {beige} gray {silver}]
set columns [list Color Hex Decimal Float]
proc insert {w parent color} {
    lassign [winfo rgb . $color] r g b
    set num [expr {($r>>8) << 16 | ($g>>8) << 8 | ($b>>8)}]
    $w insert $parent end -id $color -text [string totitle $color] -values [list [format "#%06X" $num] $num [expr {$num*1.1111}]]
}
proc create {w} {
    ::ttk::style configure Treeview -rowheight 20 -headingheight 20
    ::ttk::treeview .tv -columns [lrange $::columns 1 end] -show {tree headings} \
	-height 10 -rowheight 20 -headingheight 20 \
	-xscrollcommand [list .sx set] -yscrollcommand [list .sy set]
    ::ttk::scrollbar .sx -orient horizontal -command [list .tv xview]
    ::ttk::scrollbar .sy -orient vertical -command [list .tv yview]
    grid .tv .sy -sticky nsew
    grid .sx -sticky nsew
    grid columnconfigure . 0 -weight 1
    grid rowconfigure . 0 -weight 1
    set i -1
    foreach col $::columns {
	.tv heading [format "#%d" [incr i]] -text $col
    }
    foreach {color children} $::colors {
	set id [insert .tv {} $color]
	foreach child $children {
	    insert .tv $id $child
	}
    }
    .tv expand -recurse {}
    tkwait visibility .tv
    wm geometry . 800x250
    update
    update idletasks
    focus .tv
    return .tv
}
proc fixed_table {w} {
    ttk::style configure Treeview -font {Arial 10} -rowheight 20 -headingheight 0
    ttk::style configure Heading -font {Arial 10}
    $w configure -height 10 -rowheight 20 -headingheight 20
    update
}

proc columns_no_stretch {w} {
    set columns [concat #0 [$w cget -columns]]
    $w configure -columns [lrange $columns 1 end]
    foreach column $columns {
	$w column $column -width 200 -stretch 0
    }
    update
    update idletasks
}
proc columns_stretch {w} {
    set columns [concat #0 [$w cget -columns]]
    $w configure -columns [lrange $columns 1 end]
    foreach column $columns {
	$w column $column -width 200 -stretch 1
    }
    update
    update idletasks
}
proc lcompare {list1 list2} {foreach e1 $list1 e2 $list2 {if {$e1 ne $e2} {return 0}};return 1}
proc checkorder {item} {set index 0; foreach child [.tv children $item] {if {[.tv index $child] != $index} {return 0} else {incr index}};return 1}
proc wait {time} {set ::_temp 0;after $time [list set ::_temp 1];vwait ::_temp}
proc ButtonPress {w item {column {#0}} {offset 0}} {
    focus -force $w
    $w see $item $column
    update
    update idletasks
    wait 25
    lassign [$w bbox $item $column] x y wd h

    if {$offset > 0} {
	incr x $offset
    } else {
	incr x $wd
	incr x -10
    }
    incr y 5
    focus -force $w
    event generate $w <Button-1> -x $x -y $y
    update idletasks
    wait 25
    event generate $w <ButtonRelease-1> -x $x -y $y
    update
    update idletasks
}
proc KeyPress {w item column keysym {modifier {}} {mac_mod {}}} {
    focus -force $w

    if {$column eq {}} {
	$w focus $item
    } else {
	$w cellfocus [list $item $column]
    }
    update
    update idletasks

    if {$mac_mod ne "" && $::tcl_platform(os) eq "Darwin"} {
	set modifier $mac_mod
    }
    if {$modifier ne "" && $::tcl_platform(os) eq "Darwin"} {
	switch -- $modifier {
	    "Alt" {set modifier "Option"}
	    "Control" {set modifier "Command"}
	}
    }
    set mod [expr {$modifier ne "" ? [format "%s-" $modifier] : ""}]
    event generate $w [format "<%sKeyPress-%s>" $mod $keysym]
    update idletasks
    event generate $w [format "<%sKeyRelease-%s>" $mod $keysym]
    update
    update idletasks
}


