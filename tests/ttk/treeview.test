# Cell Selection <<TreeviewSelect>>


test Cell_Selection_TreeviewSelect_Event-68.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Cell_Selection_TreeviewSelect_Event-68.2 {Init} -body {
	.tv cellselection set [list {red #0}]
	set ecount 0
	bind .tv <<TreeviewSelect>> {incr ecount}
    }

test Cell_Selection_TreeviewSelect_Event-68.3 {Set} -body {
	.tv cellselection set [list {green #1} {blue #2}]
	update
	set ecount
    } -result {2}

test Cell_Selection_TreeviewSelect_Event-68.4 {Add} -body {
	.tv cellselection add [list {yellow #1} {orange #2}]
	update
	set ecount
    } -result {3}

test Cell_Selection_TreeviewSelect_Event-68.5 {Duplicate} -body {
	.tv cellselection add [list {yellow #1} {orange #2}]
	update
	set ecount
    } -result {3}

test Cell_Selection_TreeviewSelect_Event-68.6 {Toggle} -body {
	.tv cellselection toggle [list {yellow #1} {black #2}]
	update
	set ecount
    } -result {4}

test Cell_Selection_TreeviewSelect_Event-68.7 {Remove} -body {
	.tv cellselection add [list {black #2} {orange #2}]
	update
	set ecount
    } -result {4}

test Cell_Selection_TreeviewSelect_Event-68.8 {Delete} -body {
	.tv delete blue
	update
	set ecount
    } -result {5}

test Cell_Selection_TreeviewSelect_Event-68.9 {Clear} -body {
	.tv cellselection set {}
	update
	set ecount
    } -result {6}

test Cell_Selection_TreeviewSelect_Event-68.10 {Cleanup} -body {
	destroy .tv .sx .sy
    }

# Search and Sort Functions

# Search


test Search-69.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Search-69.2 {Too few args} -body {
	.tv search
    } -result {wrong # args: should be ".tv search parent ?-options ...? pattern"} -returnCodes {1}

test Search-69.3 {Too many args} -body {
	.tv search {*}[lrepeat 30 {}]
    } -result {wrong # args: should be ".tv search parent ?-options ...? pattern"} -returnCodes {1}

test Search-69.4 {Invalid item} -body {
	.tv search bogus pattern
    } -result {Item bogus not found} -returnCodes {1}

test Search-69.5 {Invalid arg} -body {
	.tv search {} -bogus pattern
    } -result {bad option "-bogus": must be -all, -ascii, -backwards, -cell, -columns, -dictionary, -exact, -forwards, -glob, -hidden, -integer, -nocase, -not, -real, -recurse, -recursive, -regexp, -start, -stop, -unicode, or -wraparound} -returnCodes {1}

test Search-69.6 {Ambiguous option} -body {
	.tv search {} -r pattern
    } -result {ambiguous option "-r": must be -all, -ascii, -backwards, -cell, -columns, -dictionary, -exact, -forwards, -glob, -hidden, -integer, -nocase, -not, -real, -recurse, -recursive, -regexp, -start, -stop, -unicode, or -wraparound} -returnCodes {1}

test Search-69.7 {No column} -body {
	.tv search {} -column pattern
    } -result {no column specified} -returnCodes {1}

test Search-69.8 {Invalid column} -body {
	.tv search {} -column bogus pattern
    } -result {Invalid column index "bogus"} -returnCodes {1}

test Search-69.9 {No start item} -body {
	.tv search {} -start pattern
    } -result {no start item or cell specified} -returnCodes {1}

test Search-69.10 {Invalid start item} -body {
	.tv search {} -start bogus pattern
    } -result {Item bogus not found} -returnCodes {1}

test Search-69.11 {Root start item} -body {
	.tv search {} -start {} pattern
    } -result {cannot start with root item} -returnCodes {1}

test Search-69.12 {Start item not under parent} -body {
	.tv search blue -start teal pattern
    } -result {Item teal is not a descendant of blue} -returnCodes {1}

test Search-69.13 {Invalid start cell} -body {
	.tv search {} -cell -start bogus pattern
    } -result {Cell id must be a list of two elements} -returnCodes {1}

test Search-69.14 {No stop item} -body {
	.tv search {} -stop pattern
    } -result {no stop item or cell specified} -returnCodes {1}

test Search-69.15 {Invalid stop item} -body {
	.tv search {} -stop bogus pattern
    } -result {Item bogus not found} -returnCodes {1}

test Search-69.16 {Root stop item} -body {
	.tv search {} -stop {} pattern
    } -result {cannot stop with root item} -returnCodes {1}

test Search-69.17 {Stop item not under parent} -body {
	.tv search blue -stop teal pattern
    } -result {Item teal is not a descendant of blue} -returnCodes {1}

test Search-69.18 {Invalid stop cell} -body {
	.tv search {} -cell -stop bogus pattern
    } -result {Cell id must be a list of two elements} -returnCodes {1}

test Search-69.19 {No pattern} -body {
	.tv search {} -ascii {}
    } -result {red}

test Search-69.20 {No dictionary pattern} -body {
	.tv search {} -dictionary {}
    } -result {red}

test Search-69.21 {Invalid integer} -body {
	.tv search {} -integer bogus
    } -result {expected integer but got "bogus"} -returnCodes {1}

test Search-69.22 {Invalid real} -body {
	.tv search {} -real bogus
    } -result {expected floating-point number but got "bogus"} -returnCodes {1}

test Search-69.23 {Invalid regexp} -body {
	.tv search {} -regexp "a("
    } -result {cannot compile regular expression pattern: parentheses () not balanced} -returnCodes {1}

test Search-69.24 {Empty pattern} -body {
	.tv search {} {}
    } -result {red}

test Search-69.25 {Compare ASCII Type} -body {
	.tv search {} -ascii Yellow
    } -result {yellow}

test Search-69.26 {Compare ASCII No Match} -body {
	.tv search {} -ascii Violet
    }

test Search-69.27 {Compare Dictionary Type} -body {
	.tv search {} -dictionary Green
    } -result {green}

test Search-69.28 {Compare Dictionary No Match} -body {
	.tv search {} -dictionary Violet
    }

test Search-69.29 {Compare Integer Type} -body {
	.tv search {}  -integer -column Decimal 0
    } -result {black}

test Search-69.30 {Compare Integer No Match} -body {
	.tv search {}  -integer -column Decimal 42
    }

test Search-69.31 {Compare Case Sensitive} -body {
	.tv search {}  Blue
    } -result {blue}

test Search-69.32 {Compare Case Sensitive No Match} -body {
	.tv search {}  blue
    }

test Search-69.33 {Compare Not Case Sensitive} -body {
	.tv search {} -nocase green
    } -result {green}

test Search-69.34 {Compare Not Case Sensitive No Match} -body {
	.tv search {} -nocase violet
    }

test Search-69.35 {Compare Real Type} -body {
	.tv search {} -exact -real -column Float 0
    } -result {black}

test Search-69.36 {Compare Real No Match} -body {
	.tv search {} -exact -real -column Float 42.43
    }

test Search-69.37 {Compare Unicode Type} -setup {
	.tv insert {} end -id unicode -text "\xe0\xe1\xe2\xe3\xe4\xe5\xe6\xe7\xe8\xe9\xea\xeb\xec\xed\xee\xef" -values [list #123456 42 42.43]
    } -body {
	.tv search {} -unicode -glob "*\xea*"
    } -result {unicode}

test Search-69.38 {Compare Unicode No Match} -body {
	.tv search {} -unicode -glob "*\xd0*"
    }

test Search-69.39 {Compare Unicode Type 2} -setup {
	.tv insert {} end -id unicode2 -text "\u1f00\u1f10\u1f20\u1f30\u1f40\u1f50\u1f60\u1f70\u1f80\u1f90\u1fa0\u1fb0\u1fc0\u1fd0\u1fe0" -values [list #654321 24 44.42]
    } -body {
	.tv search {} -unicode -glob "*\u1f60*"
    } -result {unicode2}

test Search-69.40 {Compare Unicode No Match 2} -body {
	.tv search {} -unicode -glob "*\u1f61*"
    }

test Search-69.41 {Direction Backwards Order} -body {
	.tv search {} -backwards -glob *n*
    } -result {brown}

test Search-69.42 {Direction Backwards No Match} -body {
	.tv search {} -backwards -glob *z*
    }

test Search-69.43 {Direction Forwards Order} -body {
	.tv search {} -forwards -glob *n*
    } -result {green}

test Search-69.44 {Direction Forwards No Match} -body {
	.tv search {} -forwards -glob *z*
    }

test Search-69.45 {Pattern Exact match} -body {
	.tv search {} -exact Green
    } -result {green}

test Search-69.46 {Pattern Exact No Match} -body {
	.tv search {} -exact Violet
    }

test Search-69.47 {Pattern Exact No Empty Match} -setup {
	.tv insert {} end -id empty -text Empty
    } -body {
	.tv search {} -exact Violet
    }

test Search-69.48 {Pattern Glob Match} -body {
	.tv search {} -glob *lue
    } -result {blue}

test Search-69.49 {Pattern Glob No Match} -body {
	.tv search {} -glob Vio*
    }

test Search-69.50 {Pattern Regexp Match} -body {
	.tv search {} -regexp {Red|Yellow}
    } -result {red}

test Search-69.51 {Pattern Regexp No Match} -body {
	.tv search {} -regexp {Violet|Amber}
    }

test Search-69.52 {Pattern Regexp All Pattern} -body {
	.tv search {} -regexp -all {[rgb]+[ef]*}
    } -result {green orange purple brown gray}

test Search-69.53 {Modifier Single Column} -body {
	.tv search {} -column #0 -all -nocase -glob *a*
    } -result {orange black gray}

test Search-69.54 {Modifier Multiple Columns} -body {
	.tv search {} -columns [list #0 Hex] -all -glob B*
    } -result {blue brown black}

test Search-69.55 {Modifier No Hidden Items} -setup {
	.tv item orange -hidden 1
    } -body {
	.tv search {} -all -glob *n*
    } -result {green brown}

test Search-69.56 {Modifier Include Hidden Items} -setup {
	.tv item orange -hidden 1
    } -body {
	.tv search {} -all -glob -hidden *n*
    } -cleanup {
	.tv item orange -hidden 0
    } -result {green orange brown}

test Search-69.57 {Modifier Recurse } -body {
	.tv search {} -recurse Cyan
    } -result {cyan}

test Search-69.58 {Modifier Recurse Glob} -body {
	.tv search {} -recurse -glob Dark*
    } -result {darkred}

test Search-69.59 {Modifier Recurse All} -body {
	.tv search {} -all -recurse -glob Dark*
    } -result {darkred darkblue}

test Search-69.60 {Modifier Recurse Not Hidden} -setup {
	.tv item orange -hidden 1
    } -body {
	.tv search {} -recurse Coral
    }

test Search-69.61 {Modifier Recurse Not Hidden Backwards} -setup {
	.tv item orange -hidden 1
    } -body {
	.tv search {} -recurse -backwards Coral
    }

test Search-69.62 {Modifier Recurse Hidden} -setup {
	.tv item orange -hidden 1
    } -body {
	.tv search {} -recurse -hidden Coral
    } -result {coral}

test Search-69.63 {Modifier Recurse Hidden Backwards} -setup {
	.tv item orange -hidden 1
    } -body {
	.tv search {} -recurse -hidden -backwards Coral
    } -cleanup {
	.tv item orange -hidden 0
    } -result {coral}

test Search-69.64 {Modifier Start Item} -body {
	.tv search {} -start blue -glob *n*
    } -result {orange}

test Search-69.65 {Modifier Start Item After Match} -body {
	.tv search {} -start black -glob *n*
    }

test Search-69.66 {Modifier Start at End} -body {
	.tv search {} -start gray -glob *n*
    }

test Search-69.67 {Modifier Stop Item} -body {
	.tv search {} -stop blue -glob *n*
    } -result {green}

test Search-69.68 {Modifier Stop Item Before Match} -body {
	.tv search {} -stop blue -glob *o*
    }

test Search-69.69 {Modifier Stop at Start} -body {
	.tv search {} -stop red -glob *n*
    }

test Search-69.70 {Modifier Start and Stop Are Same} -body {
	.tv search {} -start blue -stop blue -glob *n*
    }

test Search-69.71 {Modifier Wrap-around} -body {
	.tv search {} -start yellow -wrap Blue
    } -result {blue}

test Search-69.72 {Modifier Wrap-around No Match} -body {
	.tv search {} -start yellow -wrap Violet
    }

test Search-69.73 {Result All Modifier} -body {
	.tv search {} -all -glob *n*
    } -result {green orange brown}

test Search-69.74 {Result Single Cell} -body {
	.tv search {} -cell -glob -nocase *b*
    } -result {{blue #0}}

test Search-69.75 {Result Not Modifier} -body {
	.tv search {} -not -column #0 Red
    } -result {green}

test Search-69.76 {Multiple Columns Recurse} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse *b*
    } -result {pink darkred blue mediumblue darkblue brown wheat black beige}

test Search-69.77 {Multiple Columns Recurse with Stop Index} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -stop brown *b*
    } -result {pink darkred blue mediumblue darkblue brown}

test Search-69.78 {Multiple Cells and Columns} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -cell *b*
    } -result {{pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex} {brown #0} {wheat Hex} {black #0} {beige #0}}

test Search-69.79 {Multiple Columns with Stop Index} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -cell -stop {brown Float} *b*
    } -result {{pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex} {brown #0}}

test Search-69.80 {Multiple Columns with Start and Wrap} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -cell -start {brown #0} -wrap *b*
    } -result {{brown #0} {wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex}}

test Search-69.81 {Multiple Columns with Start, Stop, and Wrap} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -cell -start {brown #0} -stop {blue Float} -wrap *b*
    } -result {{brown #0} {wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex} {blue #0}}

