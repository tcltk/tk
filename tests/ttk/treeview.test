    } -result {cannot move root item} -returnCodes {1}

test Move-33.12 {Move under self} -body {
	.tv move red red 0
    } -result {Cannot insert red as descendant of red} -returnCodes {1}

test Move-33.13 {Move after self} -body {
	.tv move red {} 0
	lindex [.tv children {}] 0
    } -result {red}

test Move-33.14 {Move under child} -body {
	.tv move red maroon 0
    } -result {Cannot insert red as descendant of maroon} -returnCodes {1}

test Move-33.15 {Move under grandchild} -setup {
	.tv move green maroon 0
    } -body {
	.tv move red lime 0
    } -result {Cannot insert red as descendant of lime} -returnCodes {1}

test Move-33.16 {Move first to last} -body {
	.tv move red {} last
	.tv identifier {} last
    } -result {gray}

test Move-33.17 {Move end to first} -body {
	.tv move red {} first
	.tv identifier {} first
    } -result {red}

test Move-33.18 {Move first to end} -body {
	.tv move red {} end
	.tv identifier {} end
    } -result {red}

test Move-33.19 {Move item to index 0} -body {
	.tv move red {} 0
	.tv identifier {} 0
    } -result {red}

test Move-33.20 {Move item after end} -body {
	.tv move red {} 50
	.tv identifier {} 50
    } -result {red}

test Move-33.21 {Move item before start} -body {
	.tv move red {} -5
	.tv identifier {} -5
    } -result {red}

test Move-33.22 {Move item to size index} -body {
	set size [.tv size {}]
	.tv move red {} $size
	.tv identifier {} $size
    } -result {red}

test Move-33.23 {Move item to -10} -body {
	.tv move red {} -10
	.tv identifier {} -10
    } -result {red}

test Move-33.24 {Move item to size index + 1} -body {
