    } -result {21 39 180 20}

test Bbox-14.9 {Root} -body {
	.tv bbox {}
    }

test Bbox-14.10 {Detached Item} -setup {
	.tv detach white
    } -body {
	.tv bbox white
    }

test Bbox-14.11 {Item in Y view} -setup {
	fixed_cols .tv
	wm geometry . 400x300
	update
    } -body {
	.tv bbox red
    } -result {1 19 800 20}

test Bbox-14.12 {Y view scroll item out of view} -body {
	.tv yview 0
	update
	set res [list [.tv bbox red #0]]
	.tv yview 400
	update
	lappend res [.tv bbox red #0]
	set res
    } -cleanup {
	.tv yview 0
    } -result {{1 19 200 20} {}}

test Bbox-14.13 {Y view scroll item into view} -body {
	.tv yview 400
	update
	set res [list [.tv bbox red #0]]
	.tv yview 0
	update
	lappend res [.tv bbox red #0]
	set res
    } -cleanup {
	.tv yview 0
    } -result {{} {1 19 200 20}}

test Bbox-14.14 {Column in X view} -setup {
	fixed_cols .tv
	wm geometry . 400x300
	update
    } -body {
	.tv bbox red #0
    } -result {1 19 200 20}

test Bbox-14.15 {X view scroll cell out of view Bug #2381555} -body {
	.tv xview 0
	update
	set res [list [.tv bbox red #0]]
	.tv xview 200
	update
	lappend res [.tv bbox red #0]
	set res
    } -cleanup {
	.tv xview 0
    } -result {{1 19 200 20} {-199 19 200 20}}

test Bbox-14.16 {X view scroll cell into view Bug #2381555} -body {
	.tv xview 400
	update
	set res [list [.tv bbox red #0]]
	.tv xview 0
	update
	lappend res [.tv bbox red #0]
	set res
    } -cleanup {
	.tv xview 0
    } -result {{-399 19 200 20} {1 19 200 20}}

test Bbox-14.17 {Title Columns} -setup {
	.tv configure -titlecolumns 1
	.tv xview 0
	update
    } -body {
	set res [list [cell_bbox .tv blue]]
	.tv xview 400
	lappend res [cell_bbox .tv blue]
	return $res
    } -result {{{1 219 200 20} {201 219 200 20} {401 219 200 20} {601 219 200 20}} {{1 219 200 20} {-199 219 200 20} {1 219 200 20} {201 219 200 20}}}

test Bbox-14.18 {Title Rows} -setup {
	.tv configure -titleitems 1
	.tv yview 0
	update
    } -body {
	set res [list [cell_bbox .tv blue]]
	.tv yview 400
	lappend res [cell_bbox .tv blue]
	return $res
    } -result {{{1 219 200 20} {-199 219 200 20} {1 219 200 20} {201 219 200 20}} {{} {} {} {}}}

test Bbox-14.19 {Title Columns > Number of Columns} -setup {
	.tv configure -titlecolumns 5
	.tv xview 0
	update
    } -body {
	set res [list [.tv xview]]
	.tv xview 250
	lappend res [.tv xview]
	return $res
    } -result {{0.0 1.0} {0.0 1.0}}

test Bbox-14.20 {Title Rows > Number of Items} -setup {
	.tv configure -titleitems 50
	.tv yview 0
	update
    } -body {
	set res [list [.tv yview]]
	.tv yview 250
	lappend res [.tv yview]
	return $res
    } -match {glob} -result {{0.0 0.48*} {0.51* 1.0}}


