    }

test Selection_Anchor-46.5 {Set} -body {
	.tv selection anchor red
	.tv selection anchor
    } -result {red}

test Selection_Anchor-46.6 {Clear} -body {
	.tv selection anchor {}
	.tv selection anchor
    }

test Selection_Anchor-46.7 {Cleanup} -body {
