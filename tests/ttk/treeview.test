# Selection Functions

# Selection


test Selection-44.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Selection-44.2 {Invalid operation} -body {
	.tv selection bogus
    } -result {bad operation "bogus": must be add, anchor, has, includes, present, remove, set, size, or toggle} -returnCodes {1}

test Selection-44.3 {Cleanup} -body {
	destroy .tv .sx .sy
    }

# Selection Add


test Selection_Add-45.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Selection_Add-45.2 {Too few args} -body {
	.tv selection add
    } -result {wrong # args: should be ".tv selection add ?items?|?options first last?"} -returnCodes {1}

test Selection_Add-45.3 {Too many args} -body {
	.tv selection add -arg1 -arg2 first last bogus
    } -result {wrong # args: should be ".tv selection add ?items?|?options first last?"} -returnCodes {1}

test Selection_Add-45.4 {Invalid item} -body {
	.tv selection add bogus
    } -result {Item bogus not found} -returnCodes {1}

test Selection_Add-45.5 {Invalid range} -body {
	.tv selection add red bogus
    } -result {Item bogus not found} -returnCodes {1}

test Selection_Add-45.6 {Root item} -body {
	.tv selection add {}
    }

test Selection_Add-45.7 {Root range} -body {
	.tv selection add {} {}
    } -result {cannot select root item} -returnCodes {1}

test Selection_Add-45.8 {Single item} -body {
	.tv selection add red
	.tv selection
    } -result {red}

test Selection_Add-45.9 {Multiple items} -setup {
	.tv selection set red
    } -body {
	.tv selection add [list maroon green blue]
	.tv selection
    } -result {red maroon green blue}

test Selection_Add-45.10 {Range of items} -setup {
	.tv selection set red
    } -body {
	.tv selection add green orange
	.tv selection
    } -result {red green chartreuse lime olive teal blue cyan turquoise mediumblue darkblue navy orange}

test Selection_Add-45.11 {Range reverse order} -setup {
	.tv selection set red
    } -body {
	.tv selection add orange green
	.tv selection
    } -result {red green chartreuse lime olive teal blue cyan turquoise mediumblue darkblue navy orange}

test Selection_Add-45.12 {Duplicate item} -setup {
	.tv selection set red
    } -body {
	.tv selection add red
	.tv selection
    } -result {red}

test Selection_Add-45.13 {Duplicate Items} -setup {
	.tv selection set [list red green blue orange yellow]
    } -body {
	.tv selection add [list red green blue orange yellow]
	.tv selection
    } -result {red green blue orange yellow}

test Selection_Add-45.14 {Empty List} -setup {
	.tv selection set red
    } -body {
	.tv selection add [list]
	.tv selection
    } -result {red}

test Selection_Add-45.15 {No Closed items} -setup {
	.tv item green -open 0
    } -body {
	.tv selection add -nohidden red blue
	.tv selection
    } -cleanup {
	.tv selection set red
    } -result {red pink maroon darkred magenta green blue}

test Selection_Add-45.16 {Include Closed items} -setup {
	.tv item green -open 0
    } -body {
	.tv selection add -hidden magenta cyan
	.tv selection
    } -cleanup {
	.tv selection set red
    } -result {red magenta green chartreuse lime olive teal blue cyan}

test Selection_Add-45.17 {No Hidden items} -setup {
	.tv item green -open 1 -hidden 1
    } -body {
	.tv selection add -nohidden magenta cyan
	.tv selection
    } -cleanup {
	.tv selection set red
    } -result {red magenta blue cyan}

test Selection_Add-45.18 {Include Hidden items} -setup {
	.tv item green -open 1 -hidden 1
    } -body {
	.tv selection add -hidden magenta cyan
	.tv selection
    } -cleanup {
	.tv selection set red
    } -result {red magenta green chartreuse lime olive teal blue cyan}

test Selection_Add-45.19 {No Recurse} -body {
	.tv selection add -norecurse green blue
	.tv selection
    } -cleanup {
	.tv selection set red
    } -result {red green blue}

test Selection_Add-45.20 {Recurse} -setup {
	.tv item green -open 1 -hidden 0
    } -body {
	.tv selection add -recurse green blue
	.tv selection
    } -cleanup {
	.tv selection set red
    } -result {red green chartreuse lime olive teal blue}

test Selection_Add-45.21 {Cleanup} -body {
	destroy .tv .sx .sy
    }

