	.tv search {} -all -nocase -glob -recurse -cell -start {blue Hex} -stop {green #0} -wrap *b*
    } -result {{mediumblue #0} {darkblue #0} {darkblue Hex} {brown #0} {wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex}}

test Search-69.86 {All Cells, Backwards, and Wraparound} -body {
	.tv search {} -all -nocase -glob -recurse -cell -start {blue Hex} -stop {orange #0} -wrap -backwards *b*
    } -result {{blue #0} {darkred Hex} {pink Hex} {beige #0} {black #0} {wheat Hex} {brown #0}}

