    } -result {{brown #0} {wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex}}

test Search-73.79 {Multiple Cells with Start, Stop, and Wrap} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -cell -start brown -stop blue -wrap *b*
    } -result {{brown #0} {wheat Hex} {black #0} {beige #0} {pink Hex} {darkred Hex} {blue #0}}

test Search-73.80 {Search Setup} -body {
