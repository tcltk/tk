# Tag bind
proc cellEvent {w item col} {lassign [$w bbox $item $col] aX aY aW aH;set aX [expr {$aX + $aW / 2}];set aY [expr {$aY + $aH / 2}];event generate $w <Button-1> -x $aX -y $aY}


test Tag_Bind-77.1 {Init} -body {
	set w [create .tv]
    } -result {.tv}

test Tag_Bind-77.2 {Too few args} -body {
	.tv tag bind
    } -result {wrong # args: should be ".tv tag bind tagName ?sequence? ?script?"} -returnCodes {1}

test Tag_Bind-77.3 {Too many args} -body {
	.tv tag bind tagName sequence script bogus
    } -result {wrong # args: should be ".tv tag bind tagName ?sequence? ?script?"} -returnCodes {1}

test Tag_Bind-77.4 {Invalid tag name} -body {
	.tv tag bind newTag
    }

