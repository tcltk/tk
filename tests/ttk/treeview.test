# Insert


test Insert-31.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Insert-31.2 {Too few args} -body {
	.tv insert
    } -match {glob} -result {wrong # args: should be ".tv insert ?parent index?|?before|after item? ?-id id? ?-option value ...?"} -returnCodes {1}

test Insert-31.3 {Invalid item} -body {
	.tv insert bogus end
    } -result {Item bogus not found} -returnCodes {1}

test Insert-31.4 {Insert invalid index} -body {
	.tv insert {} bogus
    } -result {bad index "bogus": must be first, last, end, end-n, m+n, m-n, or an index number >= 0} -returnCodes {1}

test Insert-31.5 {Insert invalid before item} -body {
	.tv insert before bogus
    } -result {Item bogus not found} -returnCodes {1}

test Insert-31.6 {Insert invalid after item} -body {
	.tv insert after bogus
    } -result {Item bogus not found} -returnCodes {1}

test Insert-31.7 {Partial name} -body {
	.tv insert aft end
    } -result {Item aft not found} -returnCodes {1}

test Insert-31.8 {Insert with defaults} -body {
	.tv insert {} end
    } -match {glob} -result {I00*}

test Insert-31.9 {Insert at 0} -body {
	.tv insert {} 0 -id zero
	lindex [.tv children {}] 0
    } -result {zero}

test Insert-31.10 {Insert at index} -body {
	.tv insert {} 5 -id middle
	lindex [.tv children {}] 5
    } -result {middle}

test Insert-31.11 {Insert at end} -body {
	.tv insert {} end -id end
	lindex [.tv children {}] end
    } -result {end}

test Insert-31.12 {Insert before beginning} -body {
	.tv insert {} -1 -id before
	lindex [.tv children {}] 0
    } -result {before}

test Insert-31.13 {Insert beyond end} -body {
	.tv insert {} 100 -id beyond
	lindex [.tv children {}] end
    } -result {beyond}

test Insert-31.14 {Insert at first} -body {
	.tv insert {} first -id first
	lindex [.tv children {}] 0
    } -result {first}

test Insert-31.15 {Insert at last} -body {
	.tv insert {} last -id last
	lindex [.tv children {}] end-1
    } -result {last}

test Insert-31.16 {Insert with id} -body {
	.tv insert {} end -id new
	.tv exists new
    } -cleanup {
	.tv delete new
    } -result {1}

test Insert-31.17 {Insert duplicate id} -body {
	.tv insert {} end -id new
	.tv insert {} end -id new
    } -cleanup {
	.tv delete new
    } -result {Item new already exists} -returnCodes {1}

test Insert-31.18 {Insert with height} -body {
	.tv insert {} end -id new -height 5
	.tv item new -height
    } -cleanup {
	.tv delete new
    } -result {5}

test Insert-31.19 {Insert with hidden} -body {
	.tv insert {} end -id new -hidden 1
	.tv item new -hidden
    } -cleanup {
	.tv delete new
    } -result {1}

test Insert-31.20 {Insert with image} -body {
	.tv insert {} end -id new -image ::tk::icons::error
	.tv item new -image
    } -cleanup {
	.tv delete new
    } -result {::tk::icons::error}

test Insert-31.21 {Insert with image anchor} -body {
	.tv insert {} end -id new -imageanchor sw
