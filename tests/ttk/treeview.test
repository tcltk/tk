    } -result {Item bogus not found} -returnCodes {1}

test Move-33.6 {Invalid index} -body {
	.tv move red {} bogus
    } -result {bad index "bogus": must be first, last, end, end-n, m+n, m-n, or an index number >= 0} -returnCodes {1}

test Move-33.7 {Move invalid before item} -body {
	.tv move red before bogus
    } -result {Item bogus not found} -returnCodes {1}

test Move-33.8 {Move invalid after item} -body {
	.tv move red after bogus
    } -result {Item bogus not found} -returnCodes {1}

test Move-33.9 {Partial name} -body {
