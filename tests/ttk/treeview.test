    } -result {200 1000}

test Drag_and_Drop-8.16 {Drag beyond left edge is not allowed} -setup {
	columns_stretch .tv
    } -body {
	set res [list [.tv column #0 -width]]
	.tv drag #1 -100
	update
	lappend res [.tv column #0 -width]
	set res
    } -result {200 20}

test Drag_and_Drop-8.17 {Drag First Column} -setup {
	columns_stretch .tv
    } -body {
	set res [list [.tv column #0 -width]]
	.tv drag #0 -100
	update
	lappend res [.tv column #0 -width]
	set res
    } -result {196 20}

test Drag_and_Drop-8.18 {Drag Last Column} -setup {
	columns_stretch .tv
    } -body {
	set res [list [.tv column #3 -width]]
	.tv drag #3 1000
	update
	lappend res [.tv column #3 -width]
	set res
    } -result {197 412}

test Drag_and_Drop-8.19 {Shrink Column In Stretch Mode Adds Space to Next Column} -setup {
	columns_stretch .tv
    } -body {
	set res [list [.tv column #2 -width]]
	.tv drag #1 300
	update
	lappend res [.tv column #2 -width]
	set res
    } -result {200 285}

test Drag_and_Drop-8.20 {Expand Column In Stretch Mode Reduces Space in Next Column} -body {
	set res [list [.tv column #2 -width]]
	.tv drag #1 500
	update
	lappend res [.tv column #2 -width]
	set res
    } -result {285 85}

test Drag_and_Drop-8.21 {Shrink Column Not In Stretch Mode Does Not Change Next Column} -setup {
	columns_no_stretch .tv
    } -body {
	set res [list [.tv column #2 -width]]
	.tv drag #1 300
	update
	lappend res [.tv column #2 -width]
	set res
    } -result {200 200}

test Drag_and_Drop-8.22 {Expand Column Not In Stretch Mode Does Not Change Next Column} -setup {
	columns_no_stretch .tv
    } -body {
	set res [list [.tv column #2 -width]]
	.tv drag #1 500
	update
	lappend res [.tv column #2 -width]
	set res
    } -result {200 200}

test Drag_and_Drop-8.23 {Cleanup} -body {
	destroy .tv .sx .sy
    }


# Item functions

# Bbox
proc cell_bbox {w item} {set res [list];foreach col [concat #0 [$w cget -columns]] {lappend res [.tv bbox $item $col]};return $res}


