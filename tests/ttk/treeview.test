    }

# Selection Get


test Selection_Get-48.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Selection_Get-48.2 {Default selection} -body {
	.tv selection
    }

test Selection_Get-48.3 {Selection single} -setup {
	.tv selection set red
    } -body {
	.tv selection
    } -cleanup {
	.tv selection set {}
    } -result {red}

test Selection_Get-48.4 {Selection multiple} -setup {
	.tv selection set [list red green blue]
    } -body {
	.tv selection
    } -cleanup {
	.tv selection set {}
    } -result {red green blue}

test Selection_Get-48.5 {Selection range} -setup {
	.tv selection set red blue
    } -body {
	.tv selection
    } -cleanup {
	.tv selection set {}
    } -result {red pink maroon darkred magenta green chartreuse lime olive teal blue}

test Selection_Get-48.6 {Multiple levels} -setup {
	.tv selection set [list red magenta blue cyan gold]
    } -body {
	.tv selection
    } -cleanup {
	.tv selection set {}
    } -result {red magenta blue cyan gold}

test Selection_Get-48.7 {Cleanup} -body {
	destroy .tv .sx .sy
    }

# Selection Has


test Selection_Has-49.1 {Create} -body {
	set w [create .tv]
    } -result {.tv}

test Selection_Has-49.2 {Too few args} -body {
	.tv selection has
    } -result {wrong # args: should be ".tv selection has items"} -returnCodes {1}

test Selection_Has-49.3 {Too many args} -body {
	.tv selection has -arg1 -arg2 first last bogus
    } -result {wrong # args: should be ".tv selection has items"} -returnCodes {1}

test Selection_Has-49.4 {Invalid item} -body {
	.tv selection has bogus
    } -result {Item bogus not found} -returnCodes {1}

test Selection_Has-49.5 {No items} -body {
	.tv selection has {}
    } -result {0}

test Selection_Has-49.6 {Single item} -setup {
	.tv selection set red
    } -body {
	.tv selection has red
    } -cleanup {
	.tv selection set {}
    } -result {1}

test Selection_Has-49.7 {Multiple items} -setup {
	.tv selection set [list red green blue]
    } -body {
	.tv selection has [list red green blue]
    } -cleanup {
	.tv selection set {}
    } -result {1}

test Selection_Has-49.8 {Some selected items} -setup {
	.tv selection set [list red green blue]
    } -body {
	.tv selection has [list red blue]
    } -cleanup {
	.tv selection set {}
    } -result {1}

test Selection_Has-49.9 {More than selected items} -setup {
	.tv selection set [list red blue]
    } -body {
	.tv selection has [list red green blue]
    } -cleanup {
	.tv selection set {}
    } -result {0}

test Selection_Has-49.10 {Unselected item} -body {
	.tv selection has red
    } -result {0}

test Selection_Has-49.11 {Duplicate Items} -setup {
	.tv selection set [list red green blue orange yellow]
    } -body {
	.tv selection has [list red red red]
    } -cleanup {
	.tv selection set {}
    } -result {1}

test Selection_Has-49.12 {Empty List} -body {
	.tv selection has [list]
    } -result {0}

test Selection_Has-49.13 {Cleanup} -body {
	destroy .tv .sx .sy
    }

