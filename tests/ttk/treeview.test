test Detach-20.13 {Detach Detached Item} -setup {
	.tv detach white
    } -body {
	.tv detach white
	expr {"white" in [.tv children {}]}
    } -result {0}

test Detach-20.14 {Reattach} -body {
	.tv move white {} end
	lindex [.tv children {}] end
    } -result {white}

test Detach-20.15 {Cleanup} -body {
	destroy .tv .sx .sy
    }

