	update
	return $::focus
    } -result {red}

test Focus-24.12 {Clear <<TreeviewFocus>>} -body {
	.tv focus {}
	update
	return $::focus
    }

test Focus-24.13 {Cleanup} -body {
	destroy .tv .sx .sy
    }

