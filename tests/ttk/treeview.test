	.tv move red {} 1
	.tv index red
    } -result {0}

test Move-33.30 {Move child before self} -body {
	.tv move red {} 0
	.tv index red
    } -result {0}

test Move-33.31 {Check Order} -body {
	checkorder {}
    } -result {1}

test Move-33.32 {Move before first item} -body {
