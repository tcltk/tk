    } -result {{pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex} {brown #0} {wheat Hex} {black #0} {beige #0}}

test Search-73.77 {Multiple Cells with Stop Index} -body {
	.tv search {} -columns [list #0 Hex] -all -nocase -glob -recurse -cell -stop brown *b*
    } -result {{pink Hex} {darkred Hex} {blue #0} {mediumblue #0} {darkblue #0} {darkblue Hex} {brown #0}}

test Search-73.78 {Multiple Cells with Start and Wrap} -body {
