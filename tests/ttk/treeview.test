set ::test_tag ""


test Tag_Cell_Bind-75.1 {Init} -body {
	set w [create .tv]
    } -result {.tv}

test Tag_Cell_Bind-75.2 {Cell Binding} -setup {
	.tv tag configure bindTag -foreground red
	.tv tag bind bindTag <Control-t> {set ::test_tag [.tv cellfocus]}
	.tv tag cell add bindTag [list {blue Hex}]
	.tv configure -selecttype cell
    } -body {
	.tv cellfocus {blue Hex}
	event generate .tv <KeyPress> -keysym t -state 4
	event generate .tv <KeyRelease> -keysym t -state 4
	update
	set ::test_tag
    } -result {blue Hex}

test Tag_Cell_Bind-75.3 {Cleanup} -body {
	destroy .tv .sx .sy
    }

